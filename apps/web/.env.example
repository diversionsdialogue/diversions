# Sanity configuration
# Get these from https://sanity.io/manage
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01

# Optional: Required only for draft/preview mode
# Create a token at https://sanity.io/manage → API → Tokens
# SANITY_READ_TOKEN=

# Contactformulier (Fase 4 / n8n)
# Productie-webhook-URL van de n8n "Contact form"-workflow.
# LET OP: bij een statische Astro-build worden alleen PUBLIC_-vars in de client-bundle
# gezet, dus deze key MOET met PUBLIC_ beginnen. Vul de PRODUCTIE-URL in (workflow actief),
# NIET de test-URL. Workflow + handover: n8n/contactformulier.workflow.json +
# n8n/README-contactformulier.md. Voorbeeld: https://n8n.example.com/webhook/contact-diversions
PUBLIC_CONTACT_WEBHOOK_URL=
