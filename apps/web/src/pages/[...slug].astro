---
/**
 * Juridische pagina's uit de legal-collectie (Sanity `legalPage`), geserveerd op
 * hun ROOT-URL (bv. /privacy-statement, /cookie-statement) zodat de paden
 * identiek blijven aan de oude WP-URL's (inventaris/SEO). De slug komt uit het
 * document-_id (`legalPage-<slug>`, zie transforms.deriveSlug).
 *
 * Deze catch-all genereert alléén de paden uit getStaticPaths; statische
 * .astro-pagina's winnen altijd van deze route, dus er is geen conflict.
 */
import LegalLayout from "@/layouts/LegalLayout.astro";
import PortableText from "@/components/global/PortableText.astro";
import { getAllLegalPages } from "@/lib/data";

export async function getStaticPaths() {
  const legal = await getAllLegalPages();
  return legal.map((page) => ({
    params: { slug: page.slug ?? page.id },
    props: { page },
    trailingSlash: false,
  }));
}
const { page } = Astro.props;
---

<LegalLayout frontmatter={page.data}>
  <PortableText value={page.body} />
</LegalLayout>
