---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Picture from "@/components/global/Picture.astro";
import { getAllServices } from "@/lib/data";
import { zachtAfbreken } from "@/lib/afbreken";

// CONVERT-META (route A, bouwen-in-astro)
//   bron: /onze-diensten
//   nieuwe_url: /onze-diensten
//   structurele pagina (diensten-overzicht). HEEFT VERKEER -> URL behouden.
//   THEME (Fase 1, herbouw): de oude, handgemaakte 3-blokken-pagina is vervangen
//     door een Sanity-gestuurd overzicht. Sinds de nav-herindeling (Onderzoek /
//     Methodes / Branches) toont deze pagina alleen de categorie "onderzoeken";
//     methodes + oplossingen staan op /methodes, branches op /branches. Per
//     dienst een rij; de hele rij linkt naar /services/<slug>.
//   THEME: deelt nog steeds de design-stijl (sa-hero / sa-header / sa-grid /
//     sa-cta uit design/services.html). sa-hero en sa-cta zijn ongewijzigd
//     overgenomen; alleen het grid + de filter zijn nieuw.
//   AFBEELDINGEN: kaart-miniaturen komen uit service.thumbnail (Sanity). Zolang
//     die ontbreken tonen we een nette neutrale placeholder.

const allServices = await getAllServices();

// Dit overzicht toont alleen de categorie "onderzoeken". Methodes en
// oplossingen staan op /methodes, branches op /branches — dezelfde driedeling
// als de megamenu's in de hoofdnavigatie (Onderzoek / Methodes / Branches).
// Kaarten tonen de korte overzichtsvelden (overviewTitle/overviewIntro) met
// terugval op de volledige service-naam en description.
const services = allServices
  .filter((s) => (s.data.categories ?? []).includes("onderzoeken"))
  .sort((a, b) =>
    (a.data.overviewTitle || a.data.service || "").localeCompare(
      b.data.overviewTitle || b.data.service || "",
      "nl"
    )
  );
---

<BaseLayout
  seo={{
    title: "Onderzoek | Diversions",
    description:
      "Een overzicht van de onderzoeken van Diversions — van campagne-effectonderzoek tot customer journey. Bekijk alle onderzoeken en plan de weg naar groei.",
  }}
>
  <section class="sa-hero">
    <a href="#diensten" class="sa-hero-card">
      <span class="sa-hero-spark" aria-hidden="true">
        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 33l10 11 22-24"></path>
        </svg>
      </span>
      <span class="sa-hero-card-text">
        Scherper onderzoek, betere beslissingen.
      </span>
    </a>
    <div class="sa-hero-image">
      <Picture
        src="/img/onderzoeksbureau-diversions-1.jpg"
        alt="Het team van onderzoeksbureau Diversions"
        loading="eager"
      />
    </div>
  </section>

  <header class="sa-header" id="diensten">
    <div class="sa-header-left">
      <span class="sa-eyebrow">— Onderzoek</span>
      <h1 class="sa-title">
        Hoe kunnen we je helpen?
      </h1>
    </div>
  </header>

  <div class="services-list sa-services" id="sa-grid">
    {
      services.map((service, i) => {
        const slug = service.slug ?? service.id;
        return (
          <a class="service-row" href={`/services/${slug}`}>
            <span class="service-num">{String(i + 1).padStart(2, "0")}</span>
            <h3 class="service-title">{zachtAfbreken(service.data.overviewTitle || service.data.service)}</h3>
            <p class="service-desc">{service.data.overviewIntro || service.data.description}</p>
            <span class="service-arrow" aria-hidden="true">→</span>
          </a>
        );
      })
    }
  </div>

  <section class="sa-cta" style="margin-top: 96px">
    <div class="sa-cta-text">
      <span class="sa-cta-eyebrow">— Tijd voor groei?</span>
      <h2 class="sa-cta-title">
        Deel je ambities en maak<br />kennis met de mogelijkheden.
      </h2>
      <p class="sa-cta-body">
        Neem contact op om te starten. We denken met je mee en komen met een concreet,
        eerlijk voorstel terug.
      </p>
    </div>
    <a href="/contact" class="sa-cta-circle">
      Maak een afspraak
      <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>
