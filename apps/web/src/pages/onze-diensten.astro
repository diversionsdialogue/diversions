---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllServices } from "@/lib/data";
// Neutrale placeholder-miniatuur (diensten hebben nog geen eigen thumbnail in
// Sanity; gebruiker uploadt die later in de Studio). Geimporteerd als
// Astro-asset zodat hij geoptimaliseerd + gebundeld wordt.
import placeholderThumb from "@/images/assets/services.jpg";

// CONVERT-META (route A, bouwen-in-astro)
//   bron: /onze-diensten
//   nieuwe_url: /onze-diensten
//   structurele pagina (diensten-overzicht). HEEFT VERKEER -> URL behouden.
//   THEME (Fase 1, herbouw): de oude, handgemaakte 3-blokken-pagina is vervangen
//     door een volledig, Sanity-gestuurd overzicht van ALLE diensten. Per dienst
//     een kaart (miniatuur + titel); de hele kaart linkt naar /services/<slug>.
//     Categorie-filter (chips) is client-side (progressive enhancement): zonder
//     JS zijn alle kaarten zichtbaar.
//   THEME: deelt nog steeds de design-stijl (sa-hero / sa-header / sa-grid /
//     sa-cta uit design/services.html). sa-hero en sa-cta zijn ongewijzigd
//     overgenomen; alleen het grid + de filter zijn nieuw.
//   AFBEELDINGEN: kaart-miniaturen komen uit service.thumbnail (Sanity). Zolang
//     die ontbreken tonen we een nette neutrale placeholder.

const services = await getAllServices();

// Categorie-filter (vaste waarden uit het service-schema). Label = weergave,
// value = wat in service.data.categories staat.
const categoryFilters = [
  { value: "all", label: "Alles" },
  { value: "onderzoeken", label: "Onderzoeken" },
  { value: "methodes", label: "Methodes" },
  { value: "oplossingen", label: "Oplossingen" },
  { value: "branches", label: "Branches" },
] as const;
---

<BaseLayout
  seo={{
    title: "Onze diensten | Diversions",
    description:
      "Een volledig overzicht van wat Diversions doet — onderzoeken, methodes, oplossingen en branches. Bekijk alle diensten en plan de weg naar groei.",
  }}
>
  <section class="sa-hero">
    <a href="#diensten" class="sa-hero-card">
      <span class="sa-hero-spark" aria-hidden="true">
        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.4">
          <path
            d="M32 8v16M32 40v16M8 32h16M40 32h16M14 14l11 11M39 39l11 11M50 14l-11 11M14 50l11-11"
          ></path>
        </svg>
      </span>
      <span class="sa-hero-card-text">
        Klaar om de weg<br />naar groei te plannen
      </span>
    </a>
    <div class="sa-hero-image">
      {/* HANDMATIG/quality (Fase 6): hero-beeld is een design-placeholder. */}
      <img src="/img/about.jpeg" alt="" />
    </div>
  </section>

  <header class="sa-header" id="diensten">
    <div class="sa-header-left">
      <span class="sa-eyebrow">— Wat we doen</span>
      <h1 class="sa-title">
        We helpen je de weg naar groei te plannen — met onderzoek en uitvoering.
      </h1>
    </div>

    <div class="sa-header-right">
      <div class="sa-tags" role="group" aria-label="Filter op categorie" id="sa-filter">
        {
          categoryFilters.map((c, i) => (
            <button
              type="button"
              class:list={["sa-tag", { active: i === 0 }]}
              data-filter={c.value}
              aria-pressed={i === 0 ? "true" : "false"}
            >
              {c.label}
            </button>
          ))
        }
      </div>
    </div>
  </header>

  <div class="sa-grid" id="sa-grid">
    {
      services.map((service) => {
        const slug = service.slug ?? service.id;
        const thumb = service.data.thumbnail?.url ?? placeholderThumb.src;
        const thumbAlt =
          service.data.thumbnail?.alt || `Miniatuur voor ${service.data.service}`;
        const cats = (service.data.categories ?? []).join(" ");
        return (
          <a
            class="sa-card"
            href={`/services/${slug}`}
            data-categories={cats}
          >
            <div class="sa-card-thumb">
              <img src={thumb} alt={thumbAlt} loading="lazy" width="600" height="400" />
            </div>
            <h3>{service.data.service}</h3>
          </a>
        );
      })
    }
  </div>

  <p class="sa-grid-empty" id="sa-grid-empty" hidden>
    Geen diensten in deze categorie.
  </p>

  <section class="sa-cta" style="margin-top: 96px">
    <div class="sa-cta-text">
      <span class="sa-cta-eyebrow">— Tijd voor groei?</span>
      <h2 class="sa-cta-title">
        Deel je ambities en maak<br />kennis met de mogelijkheden.
      </h2>
      <p class="sa-cta-body">
        Neem contact op om te starten. We denken met je mee en komen met een concreet,
        eerlijk voorstel terug.
      </p>
    </div>
    <a href="/contact" class="sa-cta-circle">
      Maak een afspraak
      <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>

<script>
  // Client-side categorie-filter (progressive enhancement).
  // Zonder JS zijn alle kaarten gewoon zichtbaar.
  const filterGroup = document.getElementById("sa-filter");
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>("#sa-grid .sa-card")
  );
  const emptyMsg = document.getElementById("sa-grid-empty");

  function applyFilter(value: string) {
    let visible = 0;
    for (const card of cards) {
      const cats = (card.dataset.categories ?? "").split(/\s+/).filter(Boolean);
      const show = value === "all" || cats.includes(value);
      card.hidden = !show;
      if (show) visible++;
    }
    if (emptyMsg) emptyMsg.hidden = visible !== 0;
  }

  filterGroup?.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".sa-tag");
    if (!btn) return;
    const value = btn.dataset.filter ?? "all";

    for (const chip of filterGroup.querySelectorAll<HTMLButtonElement>(".sa-tag")) {
      const active = chip === btn;
      chip.classList.toggle("active", active);
      chip.setAttribute("aria-pressed", active ? "true" : "false");
    }
    applyFilter(value);
  });
</script>
