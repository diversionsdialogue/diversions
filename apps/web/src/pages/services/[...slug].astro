---
import readingTime from "reading-time";
import ServicesLayout from "../../layouts/ServicesLayout.astro";
import PortableText from "@/components/global/PortableText.astro";
import PretestCalculator from "@/components/calculators/PretestCalculator.astro";
import ServicePitch from "@/components/calculators/ServicePitch.astro";
import { getAllServices } from "@/lib/data";
import { portableTextToPlainText } from "@/lib/sanity/portableText";

// Dienstpagina's met een richtprijs-calculator boven de hero. Uitbreidbaar:
// voeg een slug toe en de calculator verschijnt ook daar (herbruikbaar op
// branchepagina's). Promoveer dit later eventueel naar een schema-veld.
const CALCULATOR_PAGES = new Set(["pretest"]);

export async function getStaticPaths() {
  const services = await getAllServices();
  return services.map((page) => ({
    params: { slug: page.slug ?? page.id },
    props: { page },
    trailingSlash: false,
  }));
}
const { page } = Astro.props;
const showCalculator = CALCULATOR_PAGES.has(page.slug ?? page.id);

// Leestijd uit de platte tekst van de Portable-Text-body (reading-time, ~200 wpm).
const plain = portableTextToPlainText(page.body);
const minutes = plain
  ? Math.max(1, Math.round(readingTime(plain).minutes))
  : undefined;
---
<ServicesLayout
  frontmatter={page.data}
  id={page.slug ?? page.id}
  readingMinutes={minutes}
  hidePageHero={showCalculator}
>
  {
    showCalculator && (
      <ServicePitch
        slot="above"
        title={page.data.service}
        lead={page.data.description}
      >
        <PretestCalculator />
      </ServicePitch>
    )
  }
  <PortableText value={page.body} />
</ServicesLayout>
