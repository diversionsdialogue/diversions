---
import readingTime from "reading-time";
import ServicesLayout from "../../layouts/ServicesLayout.astro";
import PortableText from "@/components/global/PortableText.astro";
import PretestCalculator from "@/components/calculators/PretestCalculator.astro";
import EffectmetingCalculator from "@/components/calculators/EffectmetingCalculator.astro";
import CustomerJourneyCalculator from "@/components/calculators/CustomerJourneyCalculator.astro";
import KlanttevredenheidCalculator from "@/components/calculators/KlanttevredenheidCalculator.astro";
import ServicePitch from "@/components/calculators/ServicePitch.astro";
import { getAllServices } from "@/lib/data";
import { portableTextToPlainText } from "@/lib/sanity/portableText";
import { slugify } from "@/lib/slugify";

// Dienstpagina's met een richtprijs-calculator boven de hero. Slug → welke
// calculator. Uitbreidbaar: voeg een slug + calculator toe. Promoveer dit later
// eventueel naar een Sanity-schemaveld.
const CALCULATORS: Record<string, "pretest" | "effectmeting" | "customer-journey" | "klanttevredenheid" | "placeholder"> = {
  pretest: "pretest",
  "campagne-effectonderzoek": "effectmeting",
  "customer-journey": "customer-journey",
  klanttevredenheidsonderzoek: "klanttevredenheid",
  // Placeholder: pagina krijgt de pitch-hero + een tijdelijk calculator-blok,
  // tot de kwantitatief-calculator gebouwd is.
  "kwantitatief-onderzoek": "placeholder",
};

export async function getStaticPaths() {
  const services = await getAllServices();
  return services.map((page) => ({
    params: { slug: page.slug ?? page.id },
    props: { page },
    trailingSlash: false,
  }));
}
const { page } = Astro.props;
const slug = page.slug ?? page.id;
const calculator = CALCULATORS[slug];

// Label voor de "lees alles over …"-anchorlink onder de inleiding (incl. lidwoord).
const LEES: Record<string, string> = {
  pretest: "de pretest",
  "campagne-effectonderzoek": "het campagne-effectonderzoek",
  "customer-journey": "het customer journey onderzoek",
  klanttevredenheidsonderzoek: "het klanttevredenheidsonderzoek",
  "kwantitatief-onderzoek": "het kwantitatief onderzoek",
};
const leesLabel = LEES[slug];

// Anchor naar de "Wat is…"-kop in de body (val terug op de eerste kop).
const textOf = (b: any) =>
  (b?.children ?? []).map((c: any) => c?.text ?? "").join("").trim();
const headingBlocks = (page.body ?? []).filter(
  (b: any) => b?._type === "block" && (b.style === "h2" || b.style === "h3")
);
const watIs =
  headingBlocks.find((h: any) => /^wat is/i.test(textOf(h))) ?? headingBlocks[0];
const leesHref = watIs ? `#${slugify(textOf(watIs))}` : undefined;

// Leestijd uit de platte tekst van de Portable-Text-body (reading-time, ~200 wpm).
const plain = portableTextToPlainText(page.body);
const minutes = plain
  ? Math.max(1, Math.round(readingTime(plain).minutes))
  : undefined;
---
<ServicesLayout
  frontmatter={page.data}
  id={page.slug ?? page.id}
  readingMinutes={minutes}
  hidePageHero={!!calculator}
>
  {
    calculator && (
      <ServicePitch
        slot="above"
        title={page.data.service}
        lead={page.data.description}
        leesHref={leesHref}
        leesLabel={leesLabel}
      >
        <div id="calculator" style="scroll-margin-top: 90px">
        {calculator === "pretest" && <PretestCalculator />}
        {calculator === "effectmeting" && <EffectmetingCalculator />}
        {calculator === "customer-journey" && <CustomerJourneyCalculator />}
        {calculator === "klanttevredenheid" && <KlanttevredenheidCalculator />}
        {
          calculator === "placeholder" && (
            <div
              style="border:1px dashed color-mix(in oklch, var(--accent-deep) 45%, transparent);border-radius:var(--radius-xl,20px);background:#fff;padding:32px;text-align:center;"
            >
              <p style="font-family:var(--font-subtitle);font-weight:600;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-mute);margin:0 0 8px;">
                Prijscalculator
              </p>
              <p style="font-family:var(--font-display);font-size:clamp(20px,2.4vw,26px);line-height:1.15;color:var(--ink);margin:0 0 8px;">
                Bereken je prijsindicatie, binnenkort
              </p>
              <p style="font-family:var(--font-sans);font-size:15px;line-height:1.5;color:var(--ink-soft);margin:0 auto;max-width:46ch;">
                De prijscalculator voor kwantitatief onderzoek staat hier binnenkort.
                Wil je nu al een indicatie? <a href="/contact">Neem contact op</a>, we
                rekenen het vrijblijvend voor je uit.
              </p>
            </div>
          )
        }
        </div>
      </ServicePitch>
    )
  }
  <PortableText value={page.body} />
</ServicesLayout>
