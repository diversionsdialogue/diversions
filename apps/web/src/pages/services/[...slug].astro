---
import readingTime from "reading-time";
import ServicesLayout from "../../layouts/ServicesLayout.astro";
import PortableText from "@/components/global/PortableText.astro";
import PretestCalculator from "@/components/calculators/PretestCalculator.astro";
import EffectmetingCalculator from "@/components/calculators/EffectmetingCalculator.astro";
import CustomerJourneyCalculator from "@/components/calculators/CustomerJourneyCalculator.astro";
import KlanttevredenheidCalculator from "@/components/calculators/KlanttevredenheidCalculator.astro";
import DiepteInterviewsCalculator from "@/components/calculators/DiepteInterviewsCalculator.astro";
import GroepsdiscussieCalculator from "@/components/calculators/GroepsdiscussieCalculator.astro";
import DoelgroepOnderzoekCalculator from "@/components/calculators/DoelgroepOnderzoekCalculator.astro";
import KwantitatiefCalculator from "@/components/calculators/KwantitatiefCalculator.astro";
import KwalitatiefCalculator from "@/components/calculators/KwalitatiefCalculator.astro";
import WaardepropositieCalculator from "@/components/calculators/WaardepropositieCalculator.astro";
import ServicePitch from "@/components/calculators/ServicePitch.astro";
import { getAllServices } from "@/lib/data";
import { portableTextToPlainText } from "@/lib/sanity/portableText";
import { slugify } from "@/lib/slugify";

// Dienstpagina's met een richtprijs-calculator boven de hero. Slug → welke
// calculator. Uitbreidbaar: voeg een slug + calculator toe. Promoveer dit later
// eventueel naar een Sanity-schemaveld.
const CALCULATORS: Record<string, "pretest" | "effectmeting" | "customer-journey" | "klanttevredenheid" | "diepte-interviews" | "groepsdiscussie" | "doelgroeponderzoek" | "kwantitatief-onderzoek" | "kwalitatief-onderzoek" | "waardepropositie" | "placeholder" | "maatwerk"> = {
  pretest: "pretest",
  "campagne-effectonderzoek": "effectmeting",
  "customer-journey": "customer-journey",
  "patient-journey": "customer-journey",
  klanttevredenheidsonderzoek: "klanttevredenheid",
  "diepte-interviews": "diepte-interviews",
  groepsdiscussies: "groepsdiscussie",
  doelgroeponderzoek: "doelgroeponderzoek",
  "kwantitatief-onderzoek": "kwantitatief-onderzoek",
  "kwalitatief-onderzoek": "kwalitatief-onderzoek",
  waardepropositie: "waardepropositie",
  // Maatwerk: pitch-hero zonder prijsindicatie-knop + een blok dat uitlegt dat
  // er voor deze dienst geen calculator is (prijs op aanvraag).
  "diary-study": "maatwerk",
};

// Copy per maatwerk-dienst. anchorLabel/anchorRegex: link naar de prijs-alinea
// in de body (kop wordt live opgezocht, zodat het anker klopt zolang er een
// "Wat kost…"-kop bestaat).
const MAATWERK: Record<string, { kop: string; anchorLabel: string; anchorRegex: RegExp }> = {
  "diary-study": {
    kop: "Diary study vraagt om maatwerk",
    anchorLabel: "Wat kost een diary study",
    anchorRegex: /^wat kost/i,
  },
};

export async function getStaticPaths() {
  const services = await getAllServices();
  return services.map((page) => ({
    params: { slug: page.slug ?? page.id },
    props: { page },
    trailingSlash: false,
  }));
}
const { page } = Astro.props;
const slug = page.slug ?? page.id;
const calculator = CALCULATORS[slug];

// Label voor de "lees alles over …"-anchorlink onder de inleiding (incl. lidwoord).
const LEES: Record<string, string> = {
  pretest: "de pretest",
  "campagne-effectonderzoek": "het campagne-effectonderzoek",
  "customer-journey": "het customer journey onderzoek",
  "patient-journey": "het patient journey onderzoek",
  klanttevredenheidsonderzoek: "het klanttevredenheidsonderzoek",
  doelgroeponderzoek: "het doelgroeponderzoek",
  "kwantitatief-onderzoek": "het kwantitatief onderzoek",
  "diary-study": "de diary study",
  "kwalitatief-onderzoek": "het kwalitatief onderzoek",
  "diepte-interviews": "de diepte-interviews",
  groepsdiscussies: "de groepsdiscussie",
  waardepropositie: "het waardepropositie-onderzoek",
};
const leesLabel = LEES[slug];

// Anchor naar de "Wat is…"-kop in de body (val terug op de eerste kop).
const textOf = (b: any) =>
  (b?.children ?? []).map((c: any) => c?.text ?? "").join("").trim();
const headingBlocks = (page.body ?? []).filter(
  (b: any) => b?._type === "block" && (b.style === "h2" || b.style === "h3")
);
const watIs =
  headingBlocks.find((h: any) => /^wat is/i.test(textOf(h))) ?? headingBlocks[0];
const leesHref = watIs ? `#${slugify(textOf(watIs))}` : undefined;

// Maatwerk-blok (geen calculator): zoek de "Wat kost…"-kop voor de anchorlink
// naar de prijs-alinea. Kop live opgezocht zodat het anker blijft kloppen als
// de redactie de tekst licht wijzigt (zolang hij met "Wat kost" begint).
const maatwerkInfo = calculator === "maatwerk" ? MAATWERK[slug] : undefined;
const watKost = maatwerkInfo
  ? headingBlocks.find((h: any) => maatwerkInfo.anchorRegex.test(textOf(h)))
  : undefined;
const maatwerkAnchor = watKost ? `#${slugify(textOf(watKost))}` : undefined;

// Leestijd uit de platte tekst van de Portable-Text-body (reading-time, ~200 wpm).
const plain = portableTextToPlainText(page.body);
const minutes = plain
  ? Math.max(1, Math.round(readingTime(plain).minutes))
  : undefined;
---
<ServicesLayout
  frontmatter={page.data}
  id={page.slug ?? page.id}
  readingMinutes={minutes}
  hidePageHero={!!calculator}
>
  {
    calculator && (
      <ServicePitch
        slot="above"
        title={page.data.service}
        lead={page.data.description}
        leesHref={leesHref}
        leesLabel={leesLabel}
        showPriceButton={calculator !== "maatwerk"}
      >
        <div id="calculator" style="scroll-margin-top: 90px">
        {calculator === "pretest" && <PretestCalculator />}
        {calculator === "effectmeting" && <EffectmetingCalculator />}
        {calculator === "customer-journey" && <CustomerJourneyCalculator />}
        {calculator === "klanttevredenheid" && <KlanttevredenheidCalculator />}
        {calculator === "diepte-interviews" && <DiepteInterviewsCalculator />}
        {calculator === "groepsdiscussie" && <GroepsdiscussieCalculator />}
        {calculator === "doelgroeponderzoek" && <DoelgroepOnderzoekCalculator />}
        {calculator === "kwantitatief-onderzoek" && <KwantitatiefCalculator />}
        {calculator === "kwalitatief-onderzoek" && <KwalitatiefCalculator />}
        {calculator === "waardepropositie" && <WaardepropositieCalculator />}
        {
          calculator === "maatwerk" && maatwerkInfo && (
            <div
              style="border:1px solid color-mix(in oklch, var(--accent-deep) 30%, transparent);border-radius:var(--radius-xl,20px);background:#fff;padding:32px;text-align:center;"
            >
              <p style="font-family:var(--font-subtitle);font-weight:600;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-mute);margin:0 0 8px;">
                Prijsindicatie
              </p>
              <p style="font-family:var(--font-display);font-size:clamp(20px,2.4vw,26px);line-height:1.15;color:var(--ink);margin:0 0 8px;">
                {maatwerkInfo.kop}
              </p>
              <p style="font-family:var(--font-sans);font-size:15px;line-height:1.5;color:var(--ink-soft);margin:0 auto 12px;max-width:52ch;">
                Voor dit product kunnen we geen prijscalculator aanbieden. Wil je
                een prijsindicatie? <a href="/contact">Neem contact op</a> en we
                rekenen het vrijblijvend voor je uit.
              </p>
              {maatwerkAnchor && (
                <p style="font-family:var(--font-sans);font-size:15px;line-height:1.5;color:var(--ink-soft);margin:0 auto;max-width:52ch;">
                  Wil je weten welke factoren de prijs beïnvloeden? We laten het
                  je zien bij <a href={maatwerkAnchor}>{maatwerkInfo.anchorLabel}</a>.
                </p>
              )}
            </div>
          )
        }
        {
          calculator === "placeholder" && (
            <div
              style="border:1px dashed color-mix(in oklch, var(--accent-deep) 45%, transparent);border-radius:var(--radius-xl,20px);background:#fff;padding:32px;text-align:center;"
            >
              <p style="font-family:var(--font-subtitle);font-weight:600;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-mute);margin:0 0 8px;">
                Prijscalculator
              </p>
              <p style="font-family:var(--font-display);font-size:clamp(20px,2.4vw,26px);line-height:1.15;color:var(--ink);margin:0 0 8px;">
                Bereken je prijsindicatie, binnenkort
              </p>
              <p style="font-family:var(--font-sans);font-size:15px;line-height:1.5;color:var(--ink-soft);margin:0 auto;max-width:46ch;">
                De prijscalculator voor dit onderzoek staat hier binnenkort.
                Wil je nu al een indicatie? <a href="/contact">Neem contact op</a>, we
                rekenen het vrijblijvend voor je uit.
              </p>
            </div>
          )
        }
        </div>
      </ServicePitch>
    )
  }
  <PortableText value={page.body} />
</ServicesLayout>
