---
// Assets
import { Image } from "astro:assets";
import Blog from "@/images/assets/diversions-blog3.jpg";
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import BlogCard1 from "@/components/blog/BlogCard1.astro";
// Content
import { getAllPosts } from "@/lib/data";
import type { GetStaticPaths } from "astro";

// Paginering: 20 posts per pagina. Pagina 1 = /blog, daarna /blog/2, /blog/3, …
export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getAllPosts();
  allPosts.sort(
    (a, b) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
  );
  const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())];
  return paginate(allPosts, { pageSize: 20, props: { tags } });
}) satisfies GetStaticPaths;

const { page, tags } = Astro.props;
const pageUrl = (n: number) => (n === 1 ? "/blog" : `/blog/${n}`);
---

<BaseLayout>
  <section class="bg-white overflow-hidden relative">
    <Wrapper variant="standardWide" class="px-8 pb-0 py-12 lg:pt-24">
      <div class="grid items-end gap-4 max-w-5xl mx-auto">
        <Text
          tag="h1"
          variant="displayXL"
          class="tracking-tighter text-accent-800 text-balance"
        >
          Diversions Blog
        </Text>
      </div>
      <Image
        width="1200"
        height="630"
        class="w-full max-h-[60vh] rounded-2xl relative object-cover object-center mt-12"
        src={Blog}
        alt="Diversions Blog"
      />
    </Wrapper>
  </section>
  <section>
    <div class="bg-white 2xl:max-w-7xl mx-auto overflow-hidden relative">
      <img
        src="/shapes/2.svg"
        class="absolute w-full h-full opacity-[0.1] z-0 -left-64 sm:-left-96 -bottom-96"
        alt="your alt"
      />
      <div class="px-8 py-12 mx-auto max-w-6xl md:px-16 space-y-24">
        <div
          class="relative flex flex-wrap justify-start gap-2 max-w-xl ml-auto"
        >
          {
            tags.map((tag, index) => (
              <>
                <a
                  class="text-sm text-accent-500 font-medium hover:text-pink-700"
                  href={`/blog/tags/${tag}`}
                >
                  {tag}
                </a>
                {index < tags.length - 1 && <span class="mx-1">·</span>}
              </>
            ))
          }
        </div>
        <dl class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-24">
          {page.data.map((post) => <BlogCard1 post={post} />)}
        </dl>

        {
          page.lastPage > 1 && (
            <nav
              class="flex items-center justify-center gap-1.5 pt-4"
              aria-label="Paginering"
            >
              <a
                href={page.url.prev ?? "#"}
                aria-disabled={page.url.prev ? undefined : "true"}
                class:list={[
                  "px-3 py-2 rounded-md text-sm font-medium",
                  page.url.prev
                    ? "text-accent-500 hover:text-pink-700"
                    : "text-accent-300 pointer-events-none",
                ]}
              >
                ← Vorige
              </a>
              {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((n) => (
                <a
                  href={pageUrl(n)}
                  aria-current={n === page.currentPage ? "page" : undefined}
                  class:list={[
                    "min-w-9 text-center px-3 py-2 rounded-md text-sm font-medium",
                    n === page.currentPage
                      ? "bg-accent-800 text-white"
                      : "text-accent-500 hover:text-pink-700",
                  ]}
                >
                  {n}
                </a>
              ))}
              <a
                href={page.url.next ?? "#"}
                aria-disabled={page.url.next ? undefined : "true"}
                class:list={[
                  "px-3 py-2 rounded-md text-sm font-medium",
                  page.url.next
                    ? "text-accent-500 hover:text-pink-700"
                    : "text-accent-300 pointer-events-none",
                ]}
              >
                Volgende →
              </a>
            </nav>
          )
        }
      </div>
    </div>
  </section>
  <section class="sa-cta" style="margin: 0 auto 96px; max-width: 72rem">
    <div class="sa-cta-text">
      <span class="sa-cta-eyebrow">— Tijd voor groei?</span>
      <h2 class="sa-cta-title">
        Deel je ambities en maak<br />kennis met de mogelijkheden.
      </h2>
      <p class="sa-cta-body">
        Neem contact op om te starten. We denken met je mee en komen met een concreet,
        eerlijk voorstel terug.
      </p>
    </div>
    <a href="/contact" class="sa-cta-circle">
      Maak een afspraak
      <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>
