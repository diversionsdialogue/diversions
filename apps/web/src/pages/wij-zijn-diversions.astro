---
// Fundations
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Cta from "@/components/blocks/Cta.astro";
import PortableText from "@/components/global/PortableText.astro";
// Content — nu beheerbaar in Sanity via het `page`-documenttype.
import { getAllPages } from "@/lib/data";

const pages = await getAllPages();
const page = pages.find((p) => (p.slug ?? p.id) === "wij-zijn-diversions");

const title = page?.data.title ?? "Wij zijn Diversions";
const eyebrow = page?.data.eyebrow ?? "Over ons";
const description =
  page?.data.seo?.metaDescription ??
  "Het bureau dat werkt op het snijvlak van onderzoek en innovatie. Ons verhaal, onze wortels, ons netwerk en onze liefde voor het vak.";
---

<ArticleLayout
  title={title}
  eyebrow={eyebrow}
  image={page?.data.image}
  seo={{ title: `${title} | over ons`, description }}
>
  <PortableText value={page?.body ?? []} />

  <Wrapper
    slot="after"
    variant="standard"
    class="pb-24 grid grid-cols-1 gap-4 lg:grid-cols-3"
    id="info"
  >
    <Cta
      heading="Onderzoek"
      text="Nieuwe inzichten in de behoeften van je klant."
      buttonLabel="Lees meer"
      buttonHref="/services/onderzoeksbureau"
      variant="sage"
    />
    <Cta
      heading="Innovatie"
      text="Van idee naar succes."
      buttonLabel="Lees meer"
      buttonHref="/services/propositie-creatie-van-concept-naar-succes"
      variant="sage"
    />
    <Cta
      heading="Communicatie"
      text="Stap voor stap je resultaten verbeteren."
      buttonLabel="Lees meer"
      buttonHref="/services/conversie-optimalisatie"
      variant="sage"
    />
  </Wrapper>
</ArticleLayout>
