---
// Fundations
import ArticleLayout from "@/layouts/ArticleLayout.astro";

// CONVERT-META (route A, bouwen-in-astro)
//   bron: /data-rechten
//   nieuwe_url: /data-rechten
//   juridische pagina (AVG-rechten). Bevatte een Gravity Form (verzoek-formulier).
//   HANDMATIG (Fase 4 / forms-agent): formulier bewust niet meegenomen; bedraad in
//     Fase 4 als n8n-formulier. Velden uit WP: type verzoek (inzage/verwijderen/
//     aanpassen), te verwijderen gegevens, huidige + gecorrigeerde gegevens,
//     e-mailadres + consent. Decoratieve gif gedropt.
//   THEME (Fase 1): omgezet naar de proza-leeslayout (ArticleLayout, drop-cap UIT).
---

<ArticleLayout
  title="Data & rechten"
  eyebrow="Juridisch"
  seo={{
    title: "Data & rechten | Diversions",
    description:
      "Een beroep doen op je AVG-rechten rondom je persoonsgegevens bij Diversions Dialogue BV: inzage, verwijderen of aanpassen.",
  }}
>
  <p>
    De Algemene verordening gegevensbescherming (AVG) geeft je de mogelijkheid
    een beroep te doen op verschillende rechten rondom je persoonsgegevens. Wij
    hebben de verschillende opties op een rij gezet. Je kunt bij ons terecht voor:
  </p>
  <ul>
    <li>inzage in je persoonsgegevens;</li>
    <li>persoonsgegevens laten verwijderen;</li>
    <li>persoonsgegevens laten aanpassen.</li>
  </ul>
  <p>
    Wil je een verzoek indienen? Neem dan contact met ons op via
    <a href="mailto:info@diversions.nl">info@diversions.nl</a>. We vragen je
    daarbij aan te geven welke gegevens het betreft (bijvoorbeeld de inschrijving
    op de nieuwsbrief, een reactie op de website, of gegevens uit een inmiddels
    beeindigde zakelijke relatie) en handelen je verzoek zo snel mogelijk af.
  </p>
  {/* HANDMATIG: hier stond op WP een Gravity Form voor het indienen van een
      verzoek. Het wordt in Fase 4 als werkend n8n-formulier teruggeplaatst. */}
  <p>
    Meer over hoe wij met je persoonsgegevens omgaan lees je in ons
    <a href="/privacy-statement">privacy statement</a>.
  </p>
</ArticleLayout>
