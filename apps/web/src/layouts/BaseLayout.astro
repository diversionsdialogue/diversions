---
// Fundations
import "@/styles/global.css";
import BaseHead from "@/components/fundations/head/BaseHead.astro";
// Components
import Footer from "@/components/global/Footer.astro";
import Navigation from "@/components/global/navigation/Navigation.astro";
interface Props {
  seo?: {
    title?: string;
    description?: string;
    image?: { url: string; alt?: string };
    type?: "website" | "article";
    publishedTime?: string;
    noindex?: boolean;
    canonical?: string;
  };
  /** Paginaspecifieke Schema.org JSON-LD (bv. BreadcrumbList, BlogPosting). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  hideNavigation?: boolean;
  hideFooter?: boolean;
}
const {
  seo,
  jsonLd,
  hideNavigation = false,
  hideFooter = false,
} = Astro.props;
---

<html lang="nl" class="scroll-smooth">
  <head>
    <BaseHead seo={seo} jsonLd={jsonLd} />
    {/* Matomo staat in BaseHead (fundations/scripts/Matomo.astro, site-id 5). */}
  </head>
  <body class="bg-accent-100 p-4 md:p-6 lg:p-10 lg:pb-0 mx-auto relative overflow-x-clip">
    <a href="#main" class="skip-link">Skip naar inhoud</a>
    <div class="xl:max-w-[100rem] mx-auto">
      <!-- Diversions-shell: gepadde buitenshell (body padding) + afgeronde
           binnen-surface, conform design/site.css .shell + .surface -->
      <div class="surface flex flex-col min-h-[calc(100dvh-2rem)] lg:min-h-[calc(100dvh-2.5rem)]">
        {!hideNavigation && <Navigation />}
        <main id="main" class="grow">
          <slot />
        </main>
        {!hideFooter && <Footer />}
      </div>
    </div>
  </body>
</html>
