---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import CtaHire from "@/components/ctas/CtaHire.astro";
import { buildPageSeo, type DocumentSeo } from "@/lib/seo/pageSeo";
// Content
interface Props {
  frontmatter: {
    work: string;
    company?: string;
    client?: string;
    year?: string;
    link?: string;
    credits?: { name: string; role: string }[];
    thumbnail: { url: any; alt?: string };
    seo?: DocumentSeo;
  };
  /** Slug van deze case, voor canonical/breadcrumb (zie [...slug].astro). */
  id?: string;
}
const { frontmatter, id } = Astro.props;
const credits = frontmatter.credits ?? [];

// Titel/omschrijving voor SEO uit de case-data.
const seoTitle = frontmatter.company || frontmatter.work;
const seoDescription = frontmatter.client
  ? `Case ${frontmatter.work} voor ${frontmatter.client} door Diversions.`
  : `Case ${frontmatter.work} door Diversions.`;

// og:image uit de thumbnail (string-URL nodig; image() levert .src).
const thumb = frontmatter.thumbnail?.url;
const ogImageUrl = typeof thumb === "string" ? thumb : (thumb?.src ?? "");

// --- Structured data: BreadcrumbList (Home > Werk > deze case) ---------------
const siteUrl = import.meta.env.SITE || "https://diversions.nl";
const breadcrumbSchema = id
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: new URL("/", siteUrl).toString(),
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Werk",
          item: new URL("/work", siteUrl).toString(),
        },
        {
          "@type": "ListItem",
          position: 3,
          name: frontmatter.work,
          item: new URL(`/work/${id}`, siteUrl).toString(),
        },
      ],
    }
  : undefined;

// Document-seo (Sanity) gemerged met de case-fallbacks (titel/omschrijving/thumbnail).
const pageSeo = buildPageSeo(frontmatter.seo, {
  title: seoTitle,
  description: seoDescription,
  image: ogImageUrl ? { url: ogImageUrl, alt: frontmatter.thumbnail?.alt } : undefined,
});
---

<BaseLayout
  jsonLd={breadcrumbSchema}
  seo={pageSeo}
>
  <section class="bg-white overflow-hidden relative">
    <Wrapper variant="standard" class="py-12 lg:pt-24">
      <div class="gap-4 lflex flex-col">
        <div class="grid items-end gap-4 lg:grid-cols-3 max-w-5xl mx-auto">
          <div class="lg:col-span-2">
            <Text
              tag="h1"
              variant="displayLG"
              class="tracking-tighter text-accent-800 text-balance"
            >
              {frontmatter.company || frontmatter.work}
            </Text>
          </div>
          <Text tag="p" variant="textBase" class="font-medium text-accent-500">
            {seoDescription}
          </Text>
        </div>
        <dl class="flex flex-col gap-2 mt-24">
          {
            frontmatter.client && (
              <div class="flex items-center justify-between w-full">
                <dt class="text-accent-900 font-semibold">Klant</dt>
                <dd class="text-accent-600 font-normal">
                  {frontmatter.client}
                </dd>
              </div>
            )
          }
          {
            frontmatter.year && (
              <div class="flex items-center justify-between w-full">
                <dt class="text-accent-900 font-semibold">Jaar</dt>
                <dd class="text-accent-600 font-normal">
                  <time datetime={frontmatter.year}>{frontmatter.year}</time>
                </dd>
              </div>
            )
          }
          <div class="flex items-center justify-between w-full">
            <dt class="text-accent-900 font-semibold">Werk</dt>
            <dd class="text-accent-600 font-normal">
              {frontmatter.work}
            </dd>
          </div>
          <div>
            {
              credits.map((credit) => (
                <div class="flex items-center justify-between w-full">
                  <dt class="text-accent-900 font-semibold">{credit.name}</dt>
                  <dd class="text-accent-600 font-normal">{credit.role}</dd>
                </div>
              ))
            }
          </div>
          {
            frontmatter.link && (
              <div class="flex items-center justify-between w-full">
                <dt class="text-accent-900 font-semibold">Website</dt>
                <dd class="text-accent-600 font-normal">
                  <a href={frontmatter.link} rel="noopener noreferrer">
                    Bezoek
                  </a>
                </dd>
              </div>
            )
          }
        </dl>
      </div>
      <img
        width={1200}
        height={630}
        src={frontmatter.thumbnail.url}
        alt={frontmatter.thumbnail.alt}
        loading="lazy"
        decoding="async"
        class="w-full max-h-120 rounded-t-2xl relative object-cover object-top mt-12"
      />
      <div
        class="bg-accent-200 text-accent-600 relative rounded-b-2xl z-10 py-2 px-4 bottom-0 w-full overflow-x-hidden"
      >
        <div
          class="items-center relative animate-marquee flex gap-4 whitespace-nowrap w-max"
        >
          {
            Array.from({ length: 20 }).map(() => (
              <span>{frontmatter.company || frontmatter.work}.</span>
            ))
          }
        </div>
      </div>
      <Wrapper variant="prose" class="mt-12">
        <slot />
      </Wrapper>
    </Wrapper>
  </section>
  <CtaHire />
</BaseLayout>
