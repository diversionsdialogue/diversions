---
import { AstroSeo } from "@lexingtonthemes/seo";

interface Props {
  title?: string;
  description?: string;
  image?: {
    url: string;
    alt?: string;
  };
  type?: "website" | "article";
  publishedTime?: string;
  noindex?: boolean;
  /**
   * Canonical-override. Standaard is dat de eigen absolute pagina-URL. Een
   * detailpagina kan dit zetten vanuit `seo.canonicalUrl` (Sanity) wanneer een
   * andere URL de "officiële" versie is (bv. samengevoegde/gemigreerde content).
   */
  canonical?: string;
}

const {
  title: pageTitle,
  description: pageDescription,
  image: pageImage,
  type = "website",
  publishedTime,
  noindex = false,
  canonical: canonicalOverride,
} = Astro.props;

// Site defaults (no siteSettings collection in this project)
const siteTitle = "Diversions";
const siteDescription =
  "Diversions helpt organisaties klaar te staan voor de klant van vandaag en morgen — van onderzoek en customer journeys tot conversie en groei.";
// `import.meta.env.SITE` komt uit astro.config.mjs (`site: https://diversions.nl`).
// De fallback wordt in productie niet gebruikt, maar staat op het echte domein
// zodat canonicals nooit op een placeholder uitkomen.
const siteUrl = import.meta.env.SITE || "https://diversions.nl";

// Default deel-/og-afbeelding op site-niveau (absolute URL t.o.v. siteUrl).
// Echte 1200x630 raster (JPEG); social platforms renderen geen SVG-previews.
const defaultOgImage = new URL(
  "/img/og-default.jpg",
  siteUrl,
).toString();

// Use page-specific values or fall back to site defaults.
// Voeg " | Diversions" alleen toe als de paginatitel het merk nog niet bevat,
// zodat titels als "Contact | Diversions" niet "Contact | Diversions | Diversions"
// worden en een homepage-title die het merk al bevat exact blijft.
const title = pageTitle
  ? pageTitle.includes(siteTitle)
    ? pageTitle
    : `${pageTitle} | ${siteTitle}`
  : siteTitle;
const description = pageDescription || siteDescription;
// Canonical: expliciete override (seo.canonicalUrl) — relatief pad absoluut
// maken t.o.v. siteUrl — anders de eigen absolute pagina-URL.
const canonical = canonicalOverride
  ? canonicalOverride.startsWith("http")
    ? canonicalOverride
    : new URL(canonicalOverride, siteUrl).toString()
  : new URL(Astro.url.pathname, siteUrl).toString();

// Image: page-specifieke afbeelding (relatieve paden absoluut maken), anders de
// site-default. Zo heeft elke pagina altijd een og:image.
const rawImage = pageImage?.url || defaultOgImage;
const ogImageUrl = rawImage.startsWith("http")
  ? rawImage
  : new URL(rawImage, siteUrl).toString();
const ogImageAlt = pageImage?.alt || title;
// MIME-type afleiden uit de extensie (default jpeg; SVG-logo netjes labelen).
const ogImageType = ogImageUrl.endsWith(".svg")
  ? "image/svg+xml"
  : ogImageUrl.endsWith(".png")
    ? "image/png"
    : ogImageUrl.endsWith(".webp")
      ? "image/webp"
      : "image/jpeg";

const twitterHandle = "";
---

<AstroSeo
  title={title}
  description={description}
  canonical={canonical}
  noindex={noindex}
  openGraph={{
    url: canonical,
    title: title,
    description: description,
    images: [
      {
        url: ogImageUrl,
        width: 1200,
        height: 630,
        alt: ogImageAlt,
        type: ogImageType,
      },
    ],
    site_name: siteTitle,
    type: type,
    locale: "nl_NL",
    ...(type === "article" &&
      publishedTime && {
        article: {
          publishedTime: publishedTime,
        },
      }),
  }}
  twitter={{
    handle: twitterHandle,
    site: twitterHandle,
    cardType: "summary_large_image",
  }}
/>
