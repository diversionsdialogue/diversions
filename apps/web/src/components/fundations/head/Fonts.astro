<!--
  Diversions — self-hosted fonts (no Google Fonts; AVG + speed).
  @font-face declarations live in src/styles/global.css.
  We preload the two most-used files: Source Sans 3 (body) + Bungee (display).
-->
<link
  rel="preload"
  href="/fonts/SourceSans3-VariableFont_wght.ttf"
  as="font"
  type="font/ttf"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/Bungee-Regular.ttf"
  as="font"
  type="font/ttf"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/AnekLatin-VariableFont.ttf"
  as="font"
  type="font/ttf"
  crossorigin
/>
