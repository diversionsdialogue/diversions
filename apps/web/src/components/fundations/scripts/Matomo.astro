---
/**
 * Matomo — zelf-gehoste webanalytics (elestio), site-id 5. Staat via BaseHead
 * op elke pagina. `is:inline` zodat Astro het snippet letterlijk in de head
 * laat staan (niet bundelt/verplaatst).
 *
 * Guard: op localhost/127.0.0.1 wordt niet getrackt, zodat lokale previews de
 * statistieken niet vervuilen. De ploi.link-staging trackt wél (handig om de
 * meting vóór livegang te verifiëren); filter die desgewenst in Matomo zelf.
 */
---

<!-- Matomo -->
<script is:inline>
  var _paq = window._paq = window._paq || [];
  /* tracker methods like "setCustomDimension" should be called before "trackPageView" */
  _paq.push(['trackPageView']);
  _paq.push(['enableLinkTracking']);
  (function() {
    if (/^(localhost|127\.0\.0\.1)$/.test(location.hostname)) return;
    var u="//matomo-diversions-u67534.vm.elestio.app/";
    _paq.push(['setTrackerUrl', u+'matomo.php']);
    _paq.push(['setSiteId', '5']);
    var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
    g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
  })();
</script>
<!-- End Matomo Code -->
