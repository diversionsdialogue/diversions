---
/**
 * ServicePitch — "elevated pitch"-kop voor een dienstpagina met richtprijs-
 * calculator. Port van new design/Service Detail - Offerte Starter.html +
 * quote-starter.css (.pitch / .pitch-head / .pitch-trust), op de centrale
 * sitetokens (identiek aan colors_and_type.css).
 *
 * Sage band (#BABF9E = --color-accent-400) met links de kop (eyebrow + titel +
 * lead) en rechts een foto, daaronder de calculator (default slot) en een
 * trust-strip. Draagt de paginatitel als <h1>; daarom zet de dienstpagina de
 * standaard artikel-hero uit (ServicesLayout `hidePageHero`).
 */
import Picture from "@/components/global/Picture.astro";
import TrustStrip from "@/components/global/TrustStrip.astro";
import type { ServiceCrumb } from "@/lib/serviceCrumb";
interface Props {
  eyebrow?: string;
  /** Kruimelpad-ouder (Onderzoek/Methodes/Branches); vervangt de eyebrow. */
  crumb?: ServiceCrumb;
  /** Korte paginanaam voor het kruimelpad (overviewTitle). */
  crumbCurrent?: string;
  title: string;
  lead: string;
  image?: string;
  imageAlt?: string;
  /** Anchor naar de "Wat is…"-kop in de body (voor de "lees alles over …"-link). */
  leesHref?: string;
  /** Linktekst incl. lidwoord, bv. "het klanttevredenheidsonderzoek". */
  leesLabel?: string;
  /** Zet uit op maatwerk-pagina's zonder calculator (bv. diary study). */
  showPriceButton?: boolean;
}
const {
  eyebrow = "Diensten · Direct een prijsopgave",
  crumb,
  crumbCurrent,
  title,
  lead,
  image = "/img/onderzoeksbureau-diversions-4.jpg",
  imageAlt = "",
  leesHref,
  leesLabel,
  showPriceButton = true,
} = Astro.props;
---

<section class="pitch">
  <div class="pitch-inner">
    <div class="pitch-head">
      <div class="pitch-copy">
        {
          crumb ? (
            <nav class="crumbs crumbs--pitch" aria-label="Kruimelpad">
              <a href="/">Home</a>
              <span class="crumbs-sep" aria-hidden="true">›</span>
              <a href={crumb.href}>{crumb.label}</a>
              <span class="crumbs-sep" aria-hidden="true">›</span>
              <span class="crumbs-current" aria-current="page">{crumbCurrent ?? title}</span>
            </nav>
          ) : (
            <span class="pitch-eyebrow">{eyebrow}</span>
          )
        }
        <h1 class="pitch-title">{title}</h1>
        <p class="pitch-lead">{lead}</p>
        {
          leesHref && (
            <div class="pitch-actions">
              <a href={leesHref} class="pitch-btn pitch-btn--ghost">Over het onderzoek</a>
              {showPriceButton && (
                <a href="#calculator" class="pitch-btn">Prijsindicatie</a>
              )}
            </div>
          )
        }
      </div>
      <div class="pitch-photo">
        <Picture src={image} alt={imageAlt} loading="eager" />
      </div>
    </div>

    <slot />

    <div class="pitch-trust-wrap">
      <TrustStrip />
    </div>
  </div>
</section>

<style>
  /* Horizontale padding spiegelt .article-shell zodat de pitch edge-for-edge
     uitlijnt met de TOC + het artikel eronder. */
  .pitch {
    background: var(--color-accent-400); /* sage #BABF9E */
    border-bottom: 1px solid var(--border);
    padding: 48px 32px 52px;
  }
  @media (min-width: 900px) {
    .pitch { padding: 56px 56px 64px; }
  }
  @media (min-width: 1200px) {
    .pitch { padding: 72px 72px 84px; }
  }
  .pitch-inner { max-width: 1200px; margin: 0 auto; }

  .pitch-head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
    align-items: center;
    margin-bottom: 40px;
  }
  @media (min-width: 860px) {
    .pitch-head { grid-template-columns: 1.2fr 1fr; gap: 52px; }
  }
  .pitch-photo {
    border-radius: var(--radius-xl);
    overflow: clip;
    border: 1px solid var(--border);
    background: var(--color-accent-200);
    aspect-ratio: 16 / 11;
  }
  @media (min-width: 860px) {
    .pitch-photo { aspect-ratio: 4 / 3; }
  }
  .pitch-photo :global(picture) { display: block; width: 100%; height: 100%; }
  .pitch-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .pitch-copy { max-width: 60ch; }

  .pitch-eyebrow {
    font-family: var(--font-subtitle);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-strong);
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin: 0 0 18px;
  }
  .pitch-eyebrow::before {
    content: "";
    width: 22px;
    height: 2px;
    background: var(--ink-strong);
    display: inline-block;
  }
  .pitch-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.04;
    letter-spacing: -0.01em;
    color: var(--ink-strong);
    margin: 0 0 18px;
    max-width: 20ch;
    text-wrap: balance;
    /* Lange samenstellingen netjes binnen het vlak houden (lang=nl). */
    hyphens: auto;
    overflow-wrap: anywhere;
  }
  .pitch-lead {
    font-family: var(--font-subtitle);
    font-weight: 400;
    font-size: clamp(17px, 1.6vw, 20px);
    line-height: 1.5;
    color: var(--ink);
    margin: 0;
    max-width: 52ch;
    text-wrap: pretty;
  }

  /* Twee snelkoppelknoppen onder de inleiding. */
  .pitch-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 24px 0 0;
  }
  .pitch-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 22px;
    border-radius: var(--radius-md);
    border: 1.5px solid var(--ink-strong);
    background: var(--ink-strong);
    color: #fff;
    font-family: var(--font-subtitle);
    font-weight: 600;
    font-size: 15px;
    line-height: 1;
    text-decoration: none;
    transition: background var(--duration-base) var(--ease),
      color var(--duration-base) var(--ease),
      border-color var(--duration-base) var(--ease);
  }
  .pitch-btn:hover { background: var(--primary); border-color: var(--primary); }
  .pitch-btn--ghost {
    background: transparent;
    color: var(--ink-strong);
  }
  .pitch-btn--ghost:hover {
    background: var(--ink-strong);
    color: #fff;
    border-color: var(--ink-strong);
  }
  .pitch-btn:focus-visible { outline: 2px solid var(--ring); outline-offset: 2px; }

  /* Trust strip onder de calculator (styling in TrustStrip.astro). */
  .pitch-trust-wrap { margin-top: 32px; }
</style>

<script>
  // Tablet/mobiel: verberg de sticky prijsbalk zodra je volledig voorbij de
  // calculator bent gescrold (onderkant van de calculator boven de viewport).
  const calc = document.querySelector<HTMLElement>(".pitch .qcalc");
  const bar = calc?.querySelector<HTMLElement>("[data-stickybar]") ?? null;
  if (calc && bar) {
    let ticking = false;
    const update = () => {
      ticking = false;
      const past = calc.getBoundingClientRect().bottom < 0;
      bar.style.display = past ? "none" : "";
    };
    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    update();
  }
</script>
