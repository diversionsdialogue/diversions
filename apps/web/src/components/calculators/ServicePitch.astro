---
/**
 * ServicePitch — "elevated pitch"-kop voor een dienstpagina met richtprijs-
 * calculator. Port van new design/Service Detail - Offerte Starter.html +
 * quote-starter.css (.pitch / .pitch-head / .pitch-trust), op de centrale
 * sitetokens (identiek aan colors_and_type.css).
 *
 * Sage band (#BABF9E = --color-accent-400) met links de kop (eyebrow + titel +
 * lead) en rechts een foto, daaronder de calculator (default slot) en een
 * trust-strip. Draagt de paginatitel als <h1>; daarom zet de dienstpagina de
 * standaard artikel-hero uit (ServicesLayout `hidePageHero`).
 */
import Picture from "@/components/global/Picture.astro";
import TrustStrip from "@/components/global/TrustStrip.astro";
interface Props {
  eyebrow?: string;
  title: string;
  lead: string;
  image?: string;
  imageAlt?: string;
}
const {
  eyebrow = "Diensten · Direct een prijsopgave",
  title,
  lead,
  image = "/img/onderzoeksbureau-diversions-4.jpg",
  imageAlt = "",
} = Astro.props;
---

<section class="pitch">
  <div class="pitch-inner">
    <div class="pitch-head">
      <div class="pitch-copy">
        <span class="pitch-eyebrow">{eyebrow}</span>
        <h1 class="pitch-title">{title}</h1>
        <p class="pitch-lead">{lead}</p>
      </div>
      <div class="pitch-photo">
        <Picture src={image} alt={imageAlt} loading="eager" />
      </div>
    </div>

    <slot />

    <div class="pitch-trust-wrap">
      <TrustStrip />
    </div>
  </div>
</section>

<style>
  /* Horizontale padding spiegelt .article-shell zodat de pitch edge-for-edge
     uitlijnt met de TOC + het artikel eronder. */
  .pitch {
    background: var(--color-accent-400); /* sage #BABF9E */
    border-bottom: 1px solid var(--border);
    padding: 48px 32px 52px;
  }
  @media (min-width: 900px) {
    .pitch { padding: 56px 56px 64px; }
  }
  @media (min-width: 1200px) {
    .pitch { padding: 72px 72px 84px; }
  }
  .pitch-inner { max-width: 1200px; margin: 0 auto; }

  .pitch-head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
    align-items: center;
    margin-bottom: 40px;
  }
  @media (min-width: 860px) {
    .pitch-head { grid-template-columns: 1.2fr 1fr; gap: 52px; }
  }
  .pitch-photo {
    border-radius: var(--radius-xl);
    overflow: clip;
    border: 1px solid var(--border);
    background: var(--color-accent-200);
    aspect-ratio: 16 / 11;
  }
  @media (min-width: 860px) {
    .pitch-photo { aspect-ratio: 4 / 3; }
  }
  .pitch-photo :global(picture) { display: block; width: 100%; height: 100%; }
  .pitch-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .pitch-copy { max-width: 60ch; }

  .pitch-eyebrow {
    font-family: var(--font-subtitle);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-strong);
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin: 0 0 18px;
  }
  .pitch-eyebrow::before {
    content: "";
    width: 22px;
    height: 2px;
    background: var(--ink-strong);
    display: inline-block;
  }
  .pitch-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.04;
    letter-spacing: -0.01em;
    color: var(--ink-strong);
    margin: 0 0 18px;
    max-width: 20ch;
    text-wrap: balance;
    /* Lange samenstellingen netjes binnen het vlak houden (lang=nl). */
    hyphens: auto;
    overflow-wrap: anywhere;
  }
  .pitch-lead {
    font-family: var(--font-subtitle);
    font-weight: 400;
    font-size: clamp(17px, 1.6vw, 20px);
    line-height: 1.5;
    color: var(--ink);
    margin: 0;
    max-width: 52ch;
    text-wrap: pretty;
  }

  /* Trust strip onder de calculator (styling in TrustStrip.astro). */
  .pitch-trust-wrap { margin-top: 32px; }
</style>
