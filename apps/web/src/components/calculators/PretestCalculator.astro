---
/**
 * PretestCalculator — gestapte offerte-starter voor de pretest-dienst.
 *
 * Astro-"island" zonder framework: server-gerenderde HTML + vanilla <script>.
 * Geen externe dependencies, geen localStorage.
 *
 * Ontwerp: new design/Offertespecs/"Offerte Mobiel.dc.html" (Variant A:
 * genummerde stappen-rail + lichte prijsbalk). Witte kaart op de sage band
 * (ServicePitch). Twee configuratiestappen + een prijs die op mobiel als
 * sticky balk onderaan verschijnt en op desktop een sticky zijpaneel is.
 *
 *   Stap 1 — Voorkeur:   Snel inzicht (Direct) / Verdiepend inzicht
 *   Stap 2 — Onderzoek:  [verdiepend] Survey (Core) / Kwalitatief (Plus)
 *                        + Doelgroepen (1/2/3) + prijs
 *
 * Rekentechniek (behouden): doelgroepen = aantal groepen van 150 respondenten
 * en schaalt de respondentkosten. Bij 1 doelgroep blijven de basisprijzen
 * exact (€680 / €1.675 / €3.075). Tarieven uit Calculator-config-pretest.json;
 * leveranciersnamen worden nooit getoond.
 *
 * [koppeling nog aanleveren] — knoppen dispatchen "pretest-calculator:submit".
 */
// Inline afmetingen + kleur: set:html-content krijgt GEEN Astro-scoped styles,
// dus de SVG moet zijn grootte zelf dragen.
const TICK = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex:none;margin-top:2px;color:var(--primary)"><polyline points="20 6 9 17 4 12"/></svg>`;
---

<section class="qcalc" data-step="1" aria-label="Offerte-starter pretest">
  <div class="qc-card">
    {/* Topbar: merk + stappen-rail */}
    <div class="qc-topbar">
      <span class="qc-brand">Bereken je prijsindicatie</span>
      <ol class="qc-rail">
        <li class="qc-railstep" data-railstep="1">
          <button type="button" class="qc-pill" data-goto="1"><span class="qc-pillnum">1</span></button>
          <span class="qc-pilllabel">Voorkeur</span>
        </li>
        <li class="qc-railsep" aria-hidden="true"></li>
        <li class="qc-railstep" data-railstep="2">
          <span class="qc-pill"><span class="qc-pillnum">2</span></span>
          <span class="qc-pilllabel">Onderzoek</span>
        </li>
        <li class="qc-railsep" aria-hidden="true"></li>
        <li class="qc-railstep" data-railstep="3">
          <span class="qc-pill"><span class="qc-pillnum">3</span></span>
          <span class="qc-pilllabel">Bestellen</span>
        </li>
      </ol>
    </div>

    {/* ---------------- STAP 1 — Voorkeur ---------------- */}
    <div class="qc-panel" data-panel="1">
      <p class="qc-steplabel">Stap 1 van 3</p>
      <h2 class="qc-title">Wat heeft je voorkeur?</h2>
      <p class="qc-sub">Kies het type pretest. In de volgende stap stel je het onderzoek verder samen.</p>

      <div class="qc-choices">
        <label class="qc-choice">
          <input type="radio" name="voorkeur" value="snel" checked />
          <span class="qc-radio" aria-hidden="true"></span>
          <span class="qc-choicebody">
            <span class="qc-choicetitle">Snel inzicht</span>
            <ul class="qc-bullets">
              <li><Fragment set:html={TICK} />Binnen 1 werkdag</li>
              <li><Fragment set:html={TICK} />Met eye-tracking simulatie</li>
              <li><Fragment set:html={TICK} />150 respondenten</li>
            </ul>
          </span>
        </label>
        <label class="qc-choice">
          <input type="radio" name="voorkeur" value="verdiepend" />
          <span class="qc-radio" aria-hidden="true"></span>
          <span class="qc-choicebody">
            <span class="qc-choicetitle">Verdiepend inzicht</span>
            <ul class="qc-bullets">
              <li><Fragment set:html={TICK} />Brede beoordeling van concept</li>
              <li><Fragment set:html={TICK} />150 respondenten per doelgroep</li>
              <li><Fragment set:html={TICK} />Vragenlijst op maat</li>
            </ul>
          </span>
        </label>
      </div>

      <button type="button" class="btn btn-primary btn-arrow qc-cta" data-next>
        Bereken indicatie
      </button>
      <p class="qc-fineprint">Geen account, geen verkoopgesprek — een eerste indicatie binnen twee minuten.</p>
    </div>

    {/* ---------------- STAP 2 — Onderzoek ---------------- */}
    <div class="qc-panel" data-panel="2" hidden>
      <div class="qc-step2grid">
        <div class="qc-form">
          <button type="button" class="qc-back" data-goto="1">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Vorige stap
          </button>
          <p class="qc-steplabel">Stap 2 van 3</p>
          <h2 class="qc-title qc-title--sm">Stel je onderzoek samen</h2>

          <div class="qc-expert">
            <span class="qc-avatar" aria-hidden="true">WB</span>
            <div>
              <p class="qc-expertname">William Burghout · <span>Onderzoeksexpert</span></p>
              <p class="qc-experttext" data-expert-text>We stellen je pretest graag op volgens jouw wensen. Geef hier je voorkeuren aan.</p>
            </div>
          </div>

          <div data-field="aanpak" hidden>
            <p class="qc-fieldlabel">Kies je oplossing</p>
            <div class="qc-choices qc-choices--2">
              <label class="qc-choice">
                <input type="radio" name="aanpak" value="survey" />
                <span class="qc-radio" aria-hidden="true"></span>
                <span class="qc-choicebody">
                  <span class="qc-choicetitle">Survey</span>
                  <ul class="qc-bullets">
                    <li><Fragment set:html={TICK} />Online survey</li>
                    <li><Fragment set:html={TICK} />Mix gesloten en open vragen</li>
                  </ul>
                </span>
              </label>
              <label class="qc-choice">
                <input type="radio" name="aanpak" value="kwali" />
                <span class="qc-radio" aria-hidden="true"></span>
                <span class="qc-choicebody">
                  <span class="qc-choicetitle">Kwalitatief onderzoek</span>
                  <ul class="qc-bullets">
                    <li><Fragment set:html={TICK} />5 diepte-interviews</li>
                    <li><Fragment set:html={TICK} />Validatie van inzichten met survey</li>
                  </ul>
                </span>
              </label>
            </div>
          </div>

          {/* Snel: aantal concepten (1-3) */}
          <div data-field="concepten" hidden>
            <p class="qc-fieldlabel">Hoeveel concepten wil je testen?</p>
            <p class="qc-help">
              Test één concept of vergelijk meerdere varianten naast elkaar.
              Elk concept toetsen we op 150 respondenten.
            </p>
            <div class="qc-select-wrap">
              <select class="qc-select" data-input="concepten" aria-label="Aantal concepten">
                <option value="1">1 concept</option>
                <option value="2">2 concepten</option>
                <option value="3">3 concepten</option>
              </select>
            </div>
          </div>

          {/* Verdiepend: aantal doelgroepen (1-3) */}
          <div data-field="doelgroepen" hidden>
            <p class="qc-fieldlabel">Doelgroepen</p>
            <p class="qc-help">
              Voor het onderzoek kunnen we verschillende doelgroepen uitnodigen
              (elk 150 respondenten). Hoeveel verschillende doelgroepen wil je
              opnemen in de pretest?
            </p>
            <div class="qc-select-wrap">
              <select class="qc-select" data-input="doelgroepen" aria-label="Aantal doelgroepen">
                <option value="1">1 doelgroep</option>
                <option value="2">2 doelgroepen</option>
                <option value="3">3 doelgroepen</option>
              </select>
            </div>
          </div>

          <div class="qc-info">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            <p>Wil je meer keuzemogelijkheden? <a href="tel:+31552032193">Neem contact met ons op.</a></p>
          </div>
        </div>

        {/* Desktop: sticky zijpaneel */}
        <aside class="qc-summary">
          <div>
            <p class="qc-sumlabel">Jouw indicatie</p>
            <p class="qc-sumprice" data-price>&euro; 680</p>
            <p class="qc-sumnote">excl. btw · richtprijs op basis van je keuzes</p>
          </div>
          <div class="qc-sumdivider"></div>
          <div class="qc-sumactions">
            <button type="button" class="btn btn-primary btn-arrow" data-action="bestellen">
              Direct bestellen
            </button>
            <button type="button" class="btn btn-outline" data-action="advies">Advies aanvragen</button>
          </div>
          <p class="qc-sumfine">Geen account nodig. Na bestelling neemt een onderzoeker binnen één werkdag contact op.</p>
        </aside>
      </div>
    </div>
  </div>

  {/* Mobiel: sticky prijsbalk onderaan het scherm (alleen in stap 2) */}
  <div class="qc-stickybar" data-stickybar>
    <div class="qc-stickyprice">
      <p class="qc-sumlabel">Jouw indicatie</p>
      <p class="qc-stickyamount" data-price>&euro; 680</p>
    </div>
    <span class="qc-stickyexcl">excl. btw · richtprijs</span>
    <div class="qc-stickyactions">
      <button type="button" class="btn btn-primary btn-arrow" data-action="bestellen">
        Direct bestellen
      </button>
      <button type="button" class="btn btn-outline" data-action="advies">Advies</button>
    </div>
  </div>
</section>

<style>
  .qcalc { margin: 0; }

  .qc-card {
    background: #fff;
    border: 1px solid color-mix(in oklch, var(--accent-deep) 30%, transparent);
    border-radius: var(--radius-xl, 20px);
    overflow: clip;
    box-shadow: var(--shadow-lg);
  }

  /* Topbar + rail */
  .qc-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding: 16px 22px;
    border-bottom: 1px solid var(--border);
    background: var(--color-accent-50);
  }
  .qc-brand {
    font-family: var(--font-display);
    font-size: 20px;
    color: var(--primary);
    letter-spacing: -0.02em;
  }
  .qc-rail { display: flex; align-items: center; gap: 8px; margin: 0; padding: 0; list-style: none; }
  .qc-railstep { display: flex; align-items: center; gap: 8px; }
  .qc-railsep { width: 24px; height: 1px; background: var(--border); }
  .qc-pill {
    width: 26px; height: 26px; border-radius: 50%; border: 0; padding: 0;
    background: var(--color-base-200); color: var(--ink-mute);
    display: inline-flex; align-items: center; justify-content: center;
    font-family: var(--font-subtitle); font-weight: 700; font-size: 13px;
  }
  button.qc-pill { cursor: pointer; }
  .qc-pill .qc-tick { width: 14px; height: 14px; }
  .qc-pilllabel { font-family: var(--font-subtitle); font-weight: 600; font-size: 13px; color: var(--ink-mute); white-space: nowrap; }
  /* actieve / afgeronde stappen */
  .qc-railstep[data-state="active"] .qc-pill { background: var(--primary); color: #fff; }
  .qc-railstep[data-state="active"] .qc-pilllabel { color: var(--ink); font-weight: 700; }
  .qc-railstep[data-state="done"] .qc-pill { background: var(--primary); color: #fff; }
  .qc-railstep[data-state="done"] .qc-pilllabel { color: var(--ink-mute); }
  @media (max-width: 560px) {
    .qc-pilllabel { display: none; }
    .qc-railstep[data-state="active"] .qc-pilllabel { display: inline; }
    .qc-railsep { width: 16px; }
  }

  .qc-panel { padding: 28px 22px 32px; }
  @media (min-width: 768px) { .qc-panel { padding: 36px 36px 44px; } }
  .qc-panel[hidden] { display: none; }

  .qc-back {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    appearance: none;
    background: transparent;
    border: 0;
    padding: 4px 0;
    margin: 0 0 14px;
    cursor: pointer;
    font-family: var(--font-subtitle);
    font-weight: 600;
    font-size: 14px;
    color: var(--ink-soft);
    transition: color var(--duration-base) var(--ease);
  }
  .qc-back:hover { color: var(--primary); }
  .qc-back svg { transition: transform var(--duration-base) var(--ease); }
  .qc-back:hover svg { transform: translateX(-3px); }
  .qc-back:focus-visible { outline: 2px solid var(--ring); outline-offset: 2px; border-radius: 6px; }

  .qc-steplabel { font-family: var(--font-subtitle); font-weight: 600; font-size: 14px; color: var(--ink-soft); margin: 0 0 8px; }
  .qc-title { font-family: var(--font-display); font-size: clamp(24px, 3vw, 30px); line-height: 1.08; color: var(--ink); margin: 0 0 8px; }
  .qc-title--sm { margin-bottom: 24px; }
  .qc-sub { font-family: var(--font-sans); font-size: 15px; line-height: 1.45; color: var(--ink-soft); margin: 0 0 22px; max-width: 40ch; }

  /* Keuzekaarten */
  .qc-choices { display: grid; grid-template-columns: 1fr; gap: 14px; }
  .qc-choice {
    position: relative; display: flex; gap: 14px; padding: 18px;
    background: #fff; border: 1px solid var(--border); border-radius: var(--radius-lg);
    cursor: pointer; transition: border-color var(--duration-base) var(--ease), background var(--duration-base) var(--ease);
  }
  .qc-choice input { position: absolute; opacity: 0; width: 0; height: 0; }
  .qc-radio {
    flex: none; width: 22px; height: 22px; border-radius: 50%;
    border: 2px solid var(--border-strong); background: #fff; margin-top: 1px;
    display: inline-flex; align-items: center; justify-content: center;
    transition: border-color var(--duration-base) var(--ease);
  }
  .qc-radio::after { content: ""; width: 11px; height: 11px; border-radius: 50%; background: var(--primary); transform: scale(0); transition: transform var(--duration-base) var(--ease); }
  .qc-choice:has(input:checked) { background: var(--primary-tint); border-color: var(--primary); border-width: 2px; padding: 17px; }
  .qc-choice:has(input:checked) .qc-radio { border-color: var(--primary); }
  .qc-choice:has(input:checked) .qc-radio::after { transform: scale(1); }
  .qc-choice:has(input:focus-visible) { outline: 2px solid var(--ring); outline-offset: 2px; }
  .qc-choicebody { flex: 1; min-width: 0; }
  .qc-choicetitle { display: block; font-family: var(--font-subtitle); font-weight: 600; font-size: 17px; color: var(--ink); }
  .qc-bullets { list-style: none; margin: 12px 0 0; padding: 0; display: flex; flex-direction: column; gap: 9px; }
  .qc-bullets li { display: flex; gap: 10px; align-items: flex-start; font-family: var(--font-sans); font-size: 14px; line-height: 1.4; color: var(--ink-soft); }
  .qc-tick { flex: none; width: 15px; height: 15px; margin-top: 2px; color: var(--primary); }

  .qc-cta { width: 100%; margin-top: 22px; }
  .qc-arrow { width: 18px; height: 18px; }
  .qc-fineprint { font-family: var(--font-sans); font-size: 13px; color: var(--ink-mute); text-align: center; margin: 14px 0 0; line-height: 1.4; }

  /* Stap 2 layout */
  .qc-step2grid { display: grid; grid-template-columns: 1fr; gap: 28px; align-items: start; }
  @media (min-width: 900px) { .qc-step2grid { grid-template-columns: 1.6fr 0.9fr; gap: 40px; } }

  .qc-expert {
    display: flex; gap: 16px; padding: 18px;
    background: var(--color-pink-100); border: 1px solid var(--border);
    border-radius: var(--radius-lg); margin-bottom: 28px;
  }
  .qc-avatar {
    flex: none; width: 52px; height: 52px; border-radius: 50%;
    background: var(--color-accent-200); color: var(--ink-strong);
    font-family: var(--font-subtitle); font-weight: 700; font-size: 18px;
    display: flex; align-items: center; justify-content: center;
  }
  .qc-expertname { font-family: var(--font-subtitle); font-weight: 600; font-size: 15px; color: var(--ink); margin: 0; }
  .qc-expertname span { color: var(--ink-mute); font-weight: 500; }
  .qc-experttext { font-family: var(--font-sans); font-size: 14px; line-height: 1.5; color: var(--ink-soft); margin: 6px 0 0; }

  .qc-fieldlabel { font-family: var(--font-subtitle); font-weight: 600; font-size: 16px; color: var(--ink); margin: 0 0 12px; }
  [data-field="aanpak"] { margin-bottom: 28px; }
  [data-field][hidden] { display: none; }
  .qc-choices--2 { gap: 16px; }
  @media (min-width: 560px) { .qc-choices--2 { grid-template-columns: 1fr 1fr; } }

  .qc-help { font-family: var(--font-sans); font-size: 14px; line-height: 1.45; color: var(--ink-soft); margin: 0 0 12px; max-width: 52ch; }
  .qc-select-wrap { position: relative; margin-bottom: 18px; }
  .qc-select {
    width: 100%; height: 50px; padding: 0 44px 0 16px;
    border: 1px solid var(--border-strong); border-radius: var(--radius-md); background: #fff;
    font-family: var(--font-subtitle); font-weight: 600; font-size: 15px; color: var(--ink);
    appearance: none; -webkit-appearance: none; cursor: pointer;
  }
  .qc-select:focus-visible { outline: 2px solid var(--ring); outline-offset: 1px; }
  .qc-select-wrap::after {
    content: ""; position: absolute; right: 18px; top: 50%; width: 10px; height: 10px;
    border-right: 2px solid var(--ink-soft); border-bottom: 2px solid var(--ink-soft);
    transform: translateY(-70%) rotate(45deg); pointer-events: none;
  }
  .qc-info {
    display: flex; gap: 12px; align-items: flex-start; padding: 14px 16px;
    background: var(--color-accent-50); border: 1px solid var(--border); border-radius: var(--radius-md);
  }
  .qc-info svg { flex: none; width: 18px; height: 18px; margin-top: 1px; color: var(--accent-deep); }
  .qc-info p { font-family: var(--font-sans); font-size: 13px; line-height: 1.45; color: var(--ink-soft); margin: 0; }
  .qc-info a { font-weight: 600; }

  /* Desktop zijpaneel */
  .qc-summary {
    display: none;
    position: sticky; top: 24px;
    background: #fff; border: 1px solid var(--border); border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm); padding: 24px; flex-direction: column; gap: 18px;
  }
  @media (min-width: 900px) { .qc-summary { display: flex; } }
  .qc-sumlabel { font-family: var(--font-subtitle); font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-mute); margin: 0 0 4px; }
  .qc-sumprice { font-family: var(--font-display); font-size: 40px; line-height: 1; color: var(--ink); margin: 0 0 6px; }
  .qc-sumnote { font-family: var(--font-sans); font-size: 13px; color: var(--ink-mute); margin: 0; }
  .qc-sumdivider { height: 1px; background: var(--border); }
  .qc-sumactions { display: flex; flex-direction: column; gap: 10px; }
  .qc-sumfine { font-family: var(--font-sans); font-size: 12px; color: var(--ink-mute); line-height: 1.45; text-align: center; margin: 0; }

  /* Mobiele sticky prijsbalk */
  .qc-stickybar { display: none; }
  @media (max-width: 899px) {
    .qcalc[data-step="2"] .qc-stickybar {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 6px 12px;
      position: fixed; left: 0; right: 0; bottom: 0; z-index: 50;
      background: #fff; border-top: 1px solid var(--border);
      box-shadow: 0 -8px 22px -10px rgba(60, 50, 40, 0.16);
      padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
    }
    .qc-stickyactions { grid-column: 1 / -1; display: flex; gap: 10px; }
    .qc-stickyactions .btn { flex: 1; }
    .qc-stickyactions .btn:first-child { flex: 1.7; }
  }
  .qc-stickyprice { display: flex; align-items: baseline; gap: 8px; }
  .qc-stickyamount { font-family: var(--font-display); font-size: 26px; line-height: 1; color: var(--ink); margin: 0; }
  .qc-stickyexcl { font-family: var(--font-sans); font-size: 12px; color: var(--ink-mute); text-align: right; }
</style>

<script>
  // --- Rekentechniek (behouden) — tarieven uit Calculator-config-pretest.json.
  // Doelgroepen (g) = aantal groepen van 150 respondenten; schaalt de
  // respondentkosten. Bij g=1 zijn de basisprijzen €680 / €1.675 / €3.075.
  const RES_PER_GROEP = 150;
  const N_SESSIES = 5;
  const RATE = {
    platformBasis: 130,
    perRespondentExpress: 2,
    perCompleteKwanti: 4.5,
    surveyBasis: 250,
    begeleidingPerSessie: 80,
    analysePerSessie: 200,
    margeDirect: 250,
    margeCore: 750,
    margePlus: 750,
  };

  const nf = new Intl.NumberFormat("nl-NL");
  const euro = (n: number) => `€ ${nf.format(Math.round(n))}`;

  type State = {
    voorkeur: "snel" | "verdiepend";
    aanpak: "" | "survey" | "kwali";
    concepten: number;
    doelgroepen: number;
  };

  function priceFor(s: State): number {
    if (s.voorkeur === "snel") {
      // Snel: elk concept op 150 respondenten.
      const n = RES_PER_GROEP * s.concepten;
      return RATE.platformBasis + RATE.perRespondentExpress * n + RATE.margeDirect;
    }
    // Verdiepend: elke doelgroep is 150 respondenten.
    const n = RES_PER_GROEP * s.doelgroepen;
    if (s.aanpak === "survey") {
      return RATE.surveyBasis + RATE.perCompleteKwanti * n + RATE.margeCore;
    }
    if (s.aanpak === "kwali") {
      return (
        RATE.surveyBasis +
        RATE.perCompleteKwanti * n +
        RATE.begeleidingPerSessie * N_SESSIES +
        RATE.analysePerSessie * N_SESSIES +
        RATE.margePlus
      );
    }
    return NaN;
  }

  document.querySelectorAll<HTMLElement>(".qcalc").forEach((root) => {
    const state: State = { voorkeur: "snel", aanpak: "", concepten: 1, doelgroepen: 1 };
    let step = 1;

    const panels = root.querySelectorAll<HTMLElement>("[data-panel]");
    const railsteps = root.querySelectorAll<HTMLElement>("[data-railstep]");
    const prices = root.querySelectorAll<HTMLElement>("[data-price]");
    const aanpakField = root.querySelector<HTMLElement>('[data-field="aanpak"]')!;
    const conceptenField = root.querySelector<HTMLElement>('[data-field="concepten"]')!;
    const doelgroepenField = root.querySelector<HTMLElement>('[data-field="doelgroepen"]')!;
    const expertText = root.querySelector<HTMLElement>("[data-expert-text]")!;

    const renderRail = () => {
      railsteps.forEach((rs) => {
        const n = Number(rs.dataset.railstep);
        const pill = rs.querySelector<HTMLElement>(".qc-pill")!;
        const num = pill.querySelector<HTMLElement>(".qc-pillnum")!;
        let state2: "done" | "active" | "todo";
        if (n < step) state2 = "done";
        else if (n === step) state2 = "active";
        else state2 = "todo";
        rs.dataset.state = state2;
        num.innerHTML =
          state2 === "done"
            ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>'
            : String(n);
      });
    };

    const renderPrice = () => {
      const p = priceFor(state);
      const txt = Number.isNaN(p) ? "—" : euro(p);
      prices.forEach((el) => (el.textContent = txt));
    };

    const renderStep2 = () => {
      const verdiepend = state.voorkeur === "verdiepend";
      aanpakField.hidden = !verdiepend;
      conceptenField.hidden = verdiepend; // alleen bij Snel
      doelgroepenField.hidden = !verdiepend; // alleen bij Verdiepend
      expertText.textContent = verdiepend
        ? "We stellen de verdiepende pretest graag op volgens jouw wensen. Geef hier je voorkeuren aan."
        : "We voeren je snelle pretest uit op 150 respondenten per doelgroep. Kies hieronder het aantal doelgroepen.";
    };

    const goTo = (n: number) => {
      step = n;
      root.dataset.step = String(n);
      panels.forEach((p) => (p.hidden = p.dataset.panel !== String(n)));
      if (n === 2) renderStep2();
      renderRail();
      renderPrice();
      root.scrollIntoView({ behavior: "smooth", block: "start" });
    };

    // Stap 1: voorkeur
    root.querySelectorAll<HTMLInputElement>('input[name="voorkeur"]').forEach((inp) => {
      inp.addEventListener("change", () => {
        state.voorkeur = inp.value as State["voorkeur"];
        // verdiepend opent met Survey voorgeselecteerd (zoals het ontwerp)
        if (state.voorkeur === "verdiepend") {
          state.aanpak = "survey";
          const sv = root.querySelector<HTMLInputElement>('input[name="aanpak"][value="survey"]');
          if (sv) sv.checked = true;
        } else {
          state.aanpak = "";
        }
      });
    });

    // "Bereken indicatie" → stap 2
    root.querySelector<HTMLButtonElement>("[data-next]")!.addEventListener("click", () => goTo(2));

    // Rail terug naar stap 1
    root.querySelectorAll<HTMLButtonElement>("[data-goto]").forEach((b) => {
      b.addEventListener("click", () => goTo(Number(b.dataset.goto)));
    });

    // Stap 2: aanpak
    root.querySelectorAll<HTMLInputElement>('input[name="aanpak"]').forEach((inp) => {
      inp.addEventListener("change", () => {
        state.aanpak = inp.value as State["aanpak"];
        renderPrice();
      });
    });

    // Stap 2: concepten (Snel) + doelgroepen (Verdiepend)
    const cp = root.querySelector<HTMLSelectElement>('[data-input="concepten"]')!;
    cp.addEventListener("change", () => {
      state.concepten = Number(cp.value);
      renderPrice();
    });
    const dg = root.querySelector<HTMLSelectElement>('[data-input="doelgroepen"]')!;
    dg.addEventListener("change", () => {
      state.doelgroepen = Number(dg.value);
      renderPrice();
    });

    // Bestellen / Advies → payload-hook [koppeling nog aanleveren]
    root.querySelectorAll<HTMLButtonElement>('[data-action="bestellen"],[data-action="advies"]').forEach((btn) => {
      btn.addEventListener("click", () => {
        const p = priceFor(state);
        const payload = {
          calculator: "pretest",
          actie: btn.dataset.action,
          keuzes: { ...state },
          tier: state.voorkeur === "snel" ? "Direct" : state.aanpak === "kwali" ? "Plus" : "Core",
          richtprijs: Number.isNaN(p) ? null : Math.round(p),
        };
        root.dispatchEvent(new CustomEvent("pretest-calculator:submit", { detail: payload, bubbles: true }));
        console.info("[pretest-calculator] submit", payload);
      });
    });

    renderRail();
    renderPrice();
  });
</script>
