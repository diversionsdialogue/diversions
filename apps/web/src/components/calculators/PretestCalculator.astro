---
/**
 * PretestCalculator — interactieve richtprijs-calculator voor de pretest-dienst.
 *
 * Astro-"island" zonder framework: de HTML-schil wordt server-side gerenderd,
 * de interactie (tabs + progressive disclosure + live prijs) draait in een
 * vanilla <script> client-side. Geen externe dependencies, geen localStorage.
 *
 * Styling: het "offerte-starter"-ontwerp uit new design/quote-starter.(css|jsx)
 * — witte kaart met tabs, segmented controls en een roze resultaatblok — op de
 * centrale sitetokens uit global.css.
 *
 * Rekenlogica/copy: calculator/Calculator-config-pretest.json.
 *
 * GUARDRAIL: leveranciersnamen (panelpartner, kwali-platform, surveytool) worden
 * NOOIT getoond. Interne tarieven staan als neutraal benoemde constanten in het
 * script en produceren alleen de eindprijs.
 *
 * [koppeling nog aanleveren] — de knoppen bouwen een payload-object en dispatchen
 * een CustomEvent "pretest-calculator:submit"; de echte bestemming
 * (formulier/CRM/e-mail) wordt later op die hook aangesloten.
 */
---

<section class="qcalc" aria-label="Richtprijs-calculator pretest">
  <div class="quote-card">
    <div class="quote-tabs" role="tablist" aria-label="Offerte starten">
      <button type="button" role="tab" class="quote-tab active" data-tab="quick" aria-selected="true">
        Snel een eerste indicatie
      </button>
      <button type="button" role="tab" class="quote-tab" data-tab="advies" aria-selected="false">
        Liever direct advies
      </button>
    </div>

    {/* ---------------- Tab 1: calculator ---------------- */}
    <div class="quote-panel" data-panel="quick">
      <h2 class="quote-panel-title">Snel een eerste prijsindicatie</h2>
      <p class="quote-sub">Bereken in een paar klikken een richtprijs voor je pretest.</p>

      <div class="quote-form">
        {/* Stap 1 — Voorkeur */}
        <div class="q-field">
          <label class="q-label">Wat heeft je voorkeur?</label>
          <div class="seg" role="group" aria-label="Voorkeur" data-seg="voorkeur">
            <button type="button" data-value="snel" class="on" aria-pressed="true">Snel inzicht</button>
            <button type="button" data-value="verdiepend" aria-pressed="false">Verdiepend inzicht</button>
          </div>
          <div class="q-help" data-help-snel>
            <span class="chips">
              <span class="chip">Feedback op design &amp; inhoud</span>
              <span class="chip">Binnen een werkdag beschikbaar</span>
              <span class="chip">150 respondenten</span>
            </span>
          </div>
          <p class="q-help" data-help-verdiepend hidden>
            Cijfers én het waarom erachter. Je bepaalt de aanpak in overleg.
          </p>
        </div>

        {/* Stap 2a — Aantal uitingen (alleen bij Snel) */}
        <div class="q-field" data-field="aantalUitingen">
          <label class="q-label" for="q-uitingen">Aantal uitingen</label>
          <select class="select" id="q-uitingen" data-input="aantalUitingen">
            <option value="1">1 uiting</option>
            <option value="2">2 uitingen</option>
            <option value="3">3 uitingen</option>
          </select>
        </div>

        {/* Stap 2b — Aanpak (alleen bij Verdiepend) */}
        <div class="q-field" data-field="aanpak" hidden>
          <label class="q-label">Hoe wil je verdiepen?</label>
          <div class="seg" role="group" aria-label="Aanpak" data-seg="aanpak">
            <button type="button" data-value="survey" aria-pressed="false">Survey</button>
            <button type="button" data-value="kwali" aria-pressed="false">Kwalitatief</button>
          </div>
          <p class="q-help" data-help-survey hidden>
            Je meet bij 150 respondenten hoe je uiting overkomt: begrip, gevoel,
            onderscheid en activering. Harde cijfers die je vergelijkt tussen
            versies en in de tijd.
          </p>
          <p class="q-help" data-help-kwali hidden>
            Vijf diepte-interviews leggen bloot waaróm iets wel of niet werkt.
            Een survey op dezelfde meetlat valideert de bevindingen kwantitatief.
          </p>
        </div>

        {/* Stap 3 — Smart Survey (alleen bij aanpak = Survey) */}
        <div class="q-field" data-field="smartSurvey" hidden>
          <label class="q-label">Wil je het onderzoek verrijken met een Smart Survey?</label>
          <div class="seg" role="group" aria-label="Smart Survey" data-seg="smartSurvey">
            <button type="button" data-value="nee" class="on" aria-pressed="true">Nee</button>
            <button type="button" data-value="ja" aria-pressed="false">Ja</button>
          </div>
          <p class="q-help">
            Met behulp van AI maken we de vragenlijst interactief: respondenten
            krijgen gerichte vervolgvragen op hun antwoorden. Dat leidt tot
            scherpere inzichten, zonder extra doorlooptijd.
          </p>
        </div>
      </div>

      {/* Resultaat (altijd zichtbaar, update live) */}
      <div class="quote-result" aria-live="polite">
        <div>
          <p class="r-label">Richtprijs <span class="r-excl">· excl. btw</span></p>
          <p class="r-amount" data-price>&euro; 680</p>
          <p class="r-note" data-breakdown></p>
          <p class="r-disclaimer">Een betrouwbare prijsindicatie, geen bindende offerte.</p>
        </div>
        <div class="r-actions">
          <button type="button" class="btn btn-primary btn-arrow" data-action="bestellen">Direct bestellen</button>
          <button type="button" class="btn btn-outline" data-action="verzenden">Prijsindicatie verzenden</button>
        </div>
      </div>

      <p class="quote-contact">
        Heb je specifieke onderzoekswensen, bijvoorbeeld bij de selectie van
        doelgroepen? Neem dan contact op: <a href="tel:+31552032193">(055) 20 32 193</a>.
      </p>
    </div>

    {/* ---------------- Tab 2: direct advies ---------------- */}
    <div class="quote-panel" data-panel="advies" hidden>
      <div data-advies-form>
        <h2 class="quote-panel-title">Liever even sparren?</h2>
        <div class="advies-grid">
          <div class="q-field">
            <label class="q-label" for="a-naam">Je naam</label>
            <input class="input" id="a-naam" data-advies="naam" placeholder="Voor- en achternaam" />
          </div>
          <div class="q-field">
            <label class="q-label" for="a-mail">E-mail of telefoon</label>
            <input class="input" id="a-mail" data-advies="contact" placeholder="naam@bedrijf.nl" />
          </div>
        </div>
        <div class="advies-row">
          <p>Een kennismaking van dertig minuten. We luisteren naar je vraag en denken vrijblijvend mee. Geen verkooppraatje.</p>
          <button type="button" class="btn btn-primary btn-arrow" data-action="advies" disabled>Plan een gesprek</button>
        </div>
      </div>
      <div data-advies-done hidden>
        <h2 class="quote-panel-title">Bedankt, we nemen contact op.</h2>
        <p class="quote-sub">
          We bellen of mailen je binnen één werkdag om kort te sparren over je
          vraag. Geen verkooppraatje, geen vervolgmail.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .qcalc { margin: 0 0 8px; }

  .quote-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: clip;
  }

  /* Tabs */
  .quote-tabs {
    display: flex;
    gap: 4px;
    padding: 6px 6px 0;
    border-bottom: 1px solid var(--border);
    background: var(--color-accent-50);
  }
  .quote-tab {
    appearance: none;
    border: 0;
    background: transparent;
    font-family: var(--font-subtitle);
    font-weight: 600;
    font-size: 15px;
    color: var(--ink-soft);
    padding: 16px 20px 14px;
    cursor: pointer;
    position: relative;
    border-radius: 8px 8px 0 0;
    transition: color var(--duration-base) var(--ease), background var(--duration-base) var(--ease);
    flex: 1;
    text-align: center;
  }
  .quote-tab:hover { color: var(--ink); }
  .quote-tab.active { color: var(--ink); background: #fff; }
  .quote-tab.active::after {
    content: "";
    position: absolute;
    left: 16px;
    right: 16px;
    bottom: -1px;
    height: 2px;
    background: var(--accent-deep);
    border-radius: 2px;
  }
  @media (max-width: 560px) {
    .quote-tab { font-size: 13px; padding: 14px 10px 12px; }
  }

  /* Panel */
  .quote-panel { padding: 28px; }
  @media (min-width: 768px) { .quote-panel { padding: 32px 36px; } }
  .quote-panel-title {
    font-family: var(--font-display);
    font-size: 22px;
    line-height: 1.15;
    color: var(--ink);
    margin: 0;
  }
  .quote-sub {
    font-family: var(--font-sans);
    color: var(--ink-soft);
    margin: 8px 0 0;
  }

  .quote-form { display: flex; flex-direction: column; gap: 22px; margin-top: 24px; }
  .q-field { display: flex; flex-direction: column; gap: 10px; min-width: 0; }
  .q-field[hidden] { display: none; }
  .q-label {
    font-family: var(--font-subtitle);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .q-help {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0;
  }
  .q-help:empty { display: none; }
  .q-help .chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .q-help .chip {
    background: var(--color-accent-100);
    border-radius: 999px;
    padding: 4px 10px;
    font-size: 12px;
    color: var(--ink-soft);
  }

  /* Segmented control */
  .seg {
    display: flex;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: clip;
    background: #fff;
  }
  .seg button {
    appearance: none;
    flex: 1;
    border: 0;
    border-left: 1px solid var(--border);
    background: #fff;
    font-family: var(--font-subtitle);
    font-weight: 600;
    font-size: 14px;
    line-height: 1.2;
    color: var(--ink);
    padding: 12px 10px;
    min-height: 48px;
    cursor: pointer;
    transition: background var(--duration-base) var(--ease), color var(--duration-base) var(--ease);
  }
  .seg button:first-child { border-left: 0; }
  .seg button:hover:not(.on) { background: var(--color-accent-50); }
  .seg button.on { background: var(--color-accent-400); color: var(--ink); }
  .seg button:focus-visible { outline: 2px solid var(--ring); outline-offset: -2px; }

  /* Select + input */
  .select,
  .input {
    width: 100%;
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--ink);
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 12px 14px;
    min-height: 48px;
  }
  .select:focus-visible,
  .input:focus-visible { outline: 2px solid var(--ring); outline-offset: 1px; }

  /* Result */
  .quote-result {
    margin-top: 24px;
    padding: 24px 26px;
    border-radius: var(--radius-md);
    background: var(--color-pink-200);
    border: 1px solid color-mix(in oklch, var(--color-pink-400) 50%, transparent);
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    align-items: center;
  }
  @media (min-width: 640px) {
    .quote-result { grid-template-columns: 1fr auto; gap: 32px; }
  }
  .r-label {
    font-family: var(--font-subtitle);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-yellow-700);
    margin: 0 0 6px;
  }
  .r-excl { color: var(--ink-mute); }
  .r-amount {
    font-family: var(--font-display);
    font-size: clamp(30px, 4vw, 40px);
    line-height: 1.05;
    color: var(--ink);
    margin: 0 0 8px;
  }
  .r-note {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0;
    max-width: 46ch;
  }
  .r-note:empty { display: none; }
  .r-disclaimer {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--ink-mute);
    margin: 10px 0 0;
  }
  .r-actions { display: flex; flex-direction: column; gap: 10px; align-items: stretch; }
  @media (min-width: 640px) { .r-actions { min-width: 220px; } }

  .quote-contact {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 18px 0 0;
  }
  .quote-contact a { color: var(--ink); font-weight: 600; }

  /* Direct-advies tab */
  .advies-grid { display: grid; grid-template-columns: 1fr; gap: 18px; margin-top: 22px; }
  @media (min-width: 640px) { .advies-grid { grid-template-columns: 1fr 1fr; } }
  .advies-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-top: 22px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }
  .advies-row p {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--ink-mute);
    max-width: 40ch;
  }
  .btn[disabled] { opacity: 0.5; cursor: not-allowed; }
  [data-panel][hidden] { display: none; }
</style>

<script>
  // --- Rekenlogica (bron: Calculator-config-pretest.json) --------------------
  // Neutraal benoemde tarieven; GEEN leveranciersnamen. n = 150 vast.
  const N = 150;
  const N_SESSIES = 5;
  const RATE = {
    platformBasis: 130,
    perRespondentExpress: 2,
    perCompleteKwanti: 4.5,
    surveyBasis: 250,
    smartSurvey: 750,
    begeleidingPerSessie: 80,
    analysePerSessie: 200,
    margeDirect: 250,
    margeCore: 750,
    margePlus: 750,
  };

  const nf = new Intl.NumberFormat("nl-NL");
  const euro = (n: number) => `€ ${nf.format(Math.round(n))}`;

  type State = {
    voorkeur: "snel" | "verdiepend";
    aantalUitingen: number;
    aanpak: "" | "survey" | "kwali";
    smartSurvey: boolean;
  };

  function priceFor(s: State): { tier: string; prijs: number; methode: string; doorlooptijd: string } {
    if (s.voorkeur === "snel") {
      return {
        tier: "Direct",
        prijs: RATE.platformBasis + RATE.perRespondentExpress * N * s.aantalUitingen + RATE.margeDirect,
        methode: "Aandachtsanalyse + korte survey (5 vragen), per uiting",
        doorlooptijd: "binnen een werkdag",
      };
    }
    if (s.aanpak === "survey") {
      return {
        tier: "Core",
        prijs: (s.smartSurvey ? RATE.smartSurvey : RATE.surveyBasis) + RATE.perCompleteKwanti * N + RATE.margeCore,
        methode: s.smartSurvey
          ? "Uitgebreide survey, verrijkt met een Smart Survey (AI-doorvraag)"
          : "Uitgebreide survey op 150 respondenten",
        doorlooptijd: "in overleg",
      };
    }
    if (s.aanpak === "kwali") {
      return {
        tier: "Plus",
        prijs:
          RATE.surveyBasis +
          RATE.perCompleteKwanti * N +
          RATE.begeleidingPerSessie * N_SESSIES +
          RATE.analysePerSessie * N_SESSIES +
          RATE.margePlus,
        methode: "Kwalitatieve diepte-interviews (5 sessies) + survey ter validatie",
        doorlooptijd: "in overleg",
      };
    }
    return { tier: "", prijs: NaN, methode: "", doorlooptijd: "" };
  }

  document.querySelectorAll<HTMLElement>(".qcalc").forEach((root) => {
    // ---- Tabs --------------------------------------------------------------
    const tabs = root.querySelectorAll<HTMLButtonElement>(".quote-tab");
    const panels = root.querySelectorAll<HTMLElement>("[data-panel]");
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const name = tab.dataset.tab;
        tabs.forEach((t) => {
          const on = t === tab;
          t.classList.toggle("active", on);
          t.setAttribute("aria-selected", on ? "true" : "false");
        });
        panels.forEach((p) => {
          p.hidden = p.dataset.panel !== name;
        });
      });
    });

    // ---- State + segmented controls ---------------------------------------
    const state: State = { voorkeur: "snel", aantalUitingen: 1, aanpak: "", smartSurvey: false };

    const segSet = (name: string, value: string) => {
      const seg = root.querySelector<HTMLElement>(`[data-seg="${name}"]`);
      if (!seg) return;
      seg.querySelectorAll<HTMLButtonElement>("button").forEach((b) => {
        const on = b.dataset.value === value;
        b.classList.toggle("on", on);
        b.setAttribute("aria-pressed", on ? "true" : "false");
      });
    };

    const fields = {
      aantalUitingen: root.querySelector<HTMLElement>('[data-field="aantalUitingen"]')!,
      aanpak: root.querySelector<HTMLElement>('[data-field="aanpak"]')!,
      smartSurvey: root.querySelector<HTMLElement>('[data-field="smartSurvey"]')!,
    };
    const priceEl = root.querySelector<HTMLElement>("[data-price]")!;
    const breakdownEl = root.querySelector<HTMLElement>("[data-breakdown]")!;
    const help = {
      snel: root.querySelector<HTMLElement>("[data-help-snel]")!,
      verdiepend: root.querySelector<HTMLElement>("[data-help-verdiepend]")!,
      survey: root.querySelector<HTMLElement>("[data-help-survey]")!,
      kwali: root.querySelector<HTMLElement>("[data-help-kwali]")!,
    };

    const render = () => {
      fields.aantalUitingen.hidden = state.voorkeur !== "snel";
      fields.aanpak.hidden = state.voorkeur !== "verdiepend";
      fields.smartSurvey.hidden = !(state.voorkeur === "verdiepend" && state.aanpak === "survey");

      help.snel.hidden = state.voorkeur !== "snel";
      help.verdiepend.hidden = state.voorkeur !== "verdiepend";
      help.survey.hidden = state.aanpak !== "survey";
      help.kwali.hidden = state.aanpak !== "kwali";

      const r = priceFor(state);
      if (Number.isNaN(r.prijs)) {
        priceEl.textContent = "—";
        breakdownEl.textContent = "Kies hierboven hoe je wilt verdiepen.";
      } else {
        priceEl.textContent = euro(r.prijs);
        breakdownEl.textContent = `Wat je krijgt: ${r.methode}. Oplevering: ${r.doorlooptijd}.`;
      }
    };

    root.querySelectorAll<HTMLElement>("[data-seg]").forEach((seg) => {
      const name = seg.dataset.seg!;
      seg.querySelectorAll<HTMLButtonElement>("button").forEach((btn) => {
        btn.addEventListener("click", () => {
          const v = btn.dataset.value!;
          segSet(name, v);
          if (name === "voorkeur") state.voorkeur = v as State["voorkeur"];
          else if (name === "aanpak") state.aanpak = v as State["aanpak"];
          else if (name === "smartSurvey") state.smartSurvey = v === "ja";
          render();
        });
      });
    });

    const uitingenSel = root.querySelector<HTMLSelectElement>('[data-input="aantalUitingen"]')!;
    uitingenSel.addEventListener("change", () => {
      state.aantalUitingen = Number(uitingenSel.value);
      render();
    });

    render();

    // ---- Resultaatknoppen: payload-hook [koppeling nog aanleveren] --------
    root.querySelectorAll<HTMLButtonElement>('[data-action="bestellen"],[data-action="verzenden"]').forEach((btn) => {
      btn.addEventListener("click", () => {
        const r = priceFor(state);
        const payload = {
          calculator: "pretest",
          actie: btn.dataset.action,
          keuzes: { ...state },
          tier: r.tier,
          richtprijs: Number.isNaN(r.prijs) ? null : Math.round(r.prijs),
        };
        root.dispatchEvent(new CustomEvent("pretest-calculator:submit", { detail: payload, bubbles: true }));
        console.info("[pretest-calculator] submit", payload);
      });
    });

    // ---- Direct-advies tab -------------------------------------------------
    const adviesNaam = root.querySelector<HTMLInputElement>('[data-advies="naam"]')!;
    const adviesContact = root.querySelector<HTMLInputElement>('[data-advies="contact"]')!;
    const adviesBtn = root.querySelector<HTMLButtonElement>('[data-action="advies"]')!;
    const adviesForm = root.querySelector<HTMLElement>("[data-advies-form]")!;
    const adviesDone = root.querySelector<HTMLElement>("[data-advies-done]")!;

    const syncAdvies = () => {
      adviesBtn.disabled = !(adviesNaam.value.trim() && adviesContact.value.trim());
    };
    adviesNaam.addEventListener("input", syncAdvies);
    adviesContact.addEventListener("input", syncAdvies);
    adviesBtn.addEventListener("click", () => {
      const payload = {
        calculator: "pretest",
        actie: "advies",
        naam: adviesNaam.value.trim(),
        contact: adviesContact.value.trim(),
      };
      root.dispatchEvent(new CustomEvent("pretest-calculator:submit", { detail: payload, bubbles: true }));
      console.info("[pretest-calculator] advies", payload);
      adviesForm.hidden = true;
      adviesDone.hidden = false;
    });
  });
</script>
