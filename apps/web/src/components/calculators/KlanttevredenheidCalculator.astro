---
import "@/styles/calculators.css";
/**
 * KlanttevredenheidCalculator — gestapte offerte-starter voor
 * klanttevredenheidsonderzoek. Module-gebaseerde prijs (zie REKENMODULES.md).
 *
 *   Stap 1 — Opzet:   Respondenten (zelf aanleveren / werven) + Frequentie (eenmalig / doorlopend)
 *   Stap 2 — Pakket:  modules (multi-select) + add-ons (smart survey, persoonlijk interview)
 *
 * Prijs (alle bedragen all-in):
 *   modules: Klanttevredenheid 1500 (verplicht) + Toekomstwensen/Effectief
 *            communiceren/Concurrentiekracht elk 750
 *   smart survey  = 250 × aantal gekozen modules
 *   persoonlijk interview = 1400 (7 interviews)
 *   doorlopend    = + 3500 (meethuis + dashboard)
 *   Respondenten "werven" → geen prijs ("- -") + verwijzing naar Doelgroeponderzoek.
 *   Baseline (zelf, eenmalig, alleen Klanttevredenheid) = € 1.500.
 *
 * Stap 3 — Bestellen: samenvatting + contactformulier, POST naar de n8n-
 * webhook (PUBLIC_CALCULATOR_WEBHOOK_URL). Zie n8n/README-offerte-calculators.md.
 * [bestemming nog aanleveren] — Doelgroeponderzoek-knop wijst voorlopig naar /onze-diensten.
 */
const TICK = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex:none;margin-top:2px;color:var(--primary)"><polyline points="20 6 9 17 4 12"/></svg>`;

// PUBLIC_-prefix is vereist zodat de var in de static client-bundle terechtkomt.
const webhookUrl = import.meta.env.PUBLIC_CALCULATOR_WEBHOOK_URL ?? "";
---

<section class="qcalc" data-step="1" data-webhook={webhookUrl} aria-label="Offerte-starter klanttevredenheidsonderzoek">
  <div class="qc-card">
    <div class="qc-topbar">
      <span class="qc-brand">Bereken je prijsindicatie</span>
      <ol class="qc-rail">
        <li class="qc-railstep" data-railstep="1">
          <button type="button" class="qc-pill" data-goto="1"><span class="qc-pillnum">1</span></button>
          <span class="qc-pilllabel">Opzet</span>
        </li>
        <li class="qc-railsep" aria-hidden="true"></li>
        <li class="qc-railstep" data-railstep="2">
          <span class="qc-pill"><span class="qc-pillnum">2</span></span>
          <span class="qc-pilllabel">Pakket</span>
        </li>
        <li class="qc-railsep" aria-hidden="true"></li>
        <li class="qc-railstep" data-railstep="3">
          <span class="qc-pill"><span class="qc-pillnum">3</span></span>
          <span class="qc-pilllabel">Bestellen</span>
        </li>
      </ol>
    </div>

    <div class="qc-body">
      <div class="qc-main">
        {/* ---------------- STAP 1 — Opzet ---------------- */}
        <div class="qc-panel" data-panel="1">
          <p class="qc-steplabel">Stap 1 van 3</p>
          <h2 class="qc-title">Hoe zet je het onderzoek op?</h2>
          <p class="qc-sub">Stel het onderzoek samen zoals je wilt.</p>

          <div class="qc-group">
            <p class="qc-fieldlabel">Respondenten</p>
            <div class="qc-seg" role="group" aria-label="Respondenten" data-seg="respondenten">
              <button type="button" data-value="zelf" class="on" aria-pressed="true">Eigen bestand</button>
              <button type="button" data-value="werven" aria-pressed="false">Respondenten werven</button>
            </div>
          </div>

          <div class="qc-group">
            <p class="qc-fieldlabel">Frequentie</p>
            <div class="qc-freqcards" role="group" aria-label="Frequentie" data-seg="frequentie">
              <button type="button" data-value="eenmalig" class="qc-freqcard on" aria-pressed="true">
                <span class="qc-freqcard-title">Eenmalig</span>
                <ul class="qc-freqcard-list">
                  <li><Fragment set:html={TICK} />Gevalideerde vragenlijst</li>
                  <li><Fragment set:html={TICK} />Response optimalisatie</li>
                  <li><Fragment set:html={TICK} />Overzichtelijke rapportage</li>
                </ul>
              </button>
              <button type="button" data-value="doorlopend" class="qc-freqcard" aria-pressed="false">
                <span class="qc-freqcard-title">Doorlopend</span>
                <ul class="qc-freqcard-list">
                  <li><Fragment set:html={TICK} />Inrichting meethuis</li>
                  <li><Fragment set:html={TICK} />Ontwikkeling dashboard</li>
                  <li><Fragment set:html={TICK} />Koppeling met interne data</li>
                </ul>
              </button>
            </div>
          </div>

          <button type="button" class="btn btn-primary btn-arrow qc-cta" data-next>
            Pakket samenstellen
          </button>
        </div>

        {/* ---------------- STAP 2 — Pakket ---------------- */}
        <div class="qc-panel" data-panel="2" hidden>
          <button type="button" class="qc-back" data-goto="1">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Vorige stap
          </button>
          <p class="qc-steplabel">Stap 2 van 3</p>
          <h2 class="qc-title qc-title--sm">Kies het onderzoekspakket</h2>

          <div class="qc-expert qc-expert--photo">
            <figure class="qc-expert-fig">
              <picture>
                <source srcset="/img/william-burghout.avif" type="image/avif" />
                <source srcset="/img/william-burghout.webp" type="image/webp" />
                <img src="/img/william-burghout.png" alt="William Burghout" width="64" height="64" loading="lazy" decoding="async" />
              </picture>
              <figcaption class="qc-expert-cap">
                <b>William Burghout</b>
                <span>Hoofd Onderzoek</span>
              </figcaption>
            </figure>
            <p class="qc-experttext">
              Stel hieronder je onderzoek naar wens samen. Heb je specifieke
              onderzoekswensen? Neem dan contact met ons op:
              <a href="tel:+31552032193" class="qc-phone">055 20 32 193</a>.
            </p>
          </div>

          <div class="qc-group">
            <p class="qc-fieldlabel">Modules</p>
            <div class="qc-choices qc-choices--2">
              <label class="qc-choice">
                <input type="checkbox" name="module" value="klant" checked disabled />
                <span class="qc-radio" aria-hidden="true"></span>
                <span class="qc-choicebody">
                  <span class="qc-choicetitle">Klanttevredenheid</span>
                  <span class="qc-choicesub">Inzicht in klanttevredenheid, actiepunten om loyaliteit te verhogen.</span>
                </span>
              </label>
              <label class="qc-choice">
                <input type="checkbox" name="module" value="toekomst" />
                <span class="qc-radio" aria-hidden="true"></span>
                <span class="qc-choicebody">
                  <span class="qc-choicetitle">Toekomstwensen</span>
                  <span class="qc-choicesub">Inzicht in toekomstige klantbehoeften.</span>
                </span>
              </label>
              <label class="qc-choice">
                <input type="checkbox" name="module" value="effectief" />
                <span class="qc-radio" aria-hidden="true"></span>
                <span class="qc-choicebody">
                  <span class="qc-choicetitle">Effectief communiceren</span>
                  <span class="qc-choicesub">Beoordeling huidige communicatie, benchmark met marktstandaarden.</span>
                </span>
              </label>
              <label class="qc-choice">
                <input type="checkbox" name="module" value="concurrentie" />
                <span class="qc-radio" aria-hidden="true"></span>
                <span class="qc-choicebody">
                  <span class="qc-choicetitle">Concurrentiekracht</span>
                  <span class="qc-choicesub">Zicht op je marktpositie en kracht van propositie t.o.v. concurrenten.</span>
                </span>
              </label>
            </div>
          </div>

          <div class="qc-group">
            <p class="qc-fieldlabel">Verdieping (optioneel)</p>
            <p class="qc-help">
              Surveys geven een goed beeld van de mening en aandachtspunten van
              klanten. Wil je meer inzicht in de achterliggende motieven en
              drijfveren? Kies dan een van deze opties.
            </p>
            <div class="qc-choices qc-choices--2">
              <label class="qc-choice">
                <input type="checkbox" name="addon" value="smart" />
                <span class="qc-radio" aria-hidden="true"></span>
                <span class="qc-choicebody">
                  <span class="qc-choicetitle">Smart survey</span>
                  <span class="qc-choicesub">Met AI gericht doorvragen om klantgedrag beter te begrijpen.</span>
                </span>
              </label>
              <label class="qc-choice">
                <input type="checkbox" name="addon" value="interview" />
                <span class="qc-radio" aria-hidden="true"></span>
                <span class="qc-choicebody">
                  <span class="qc-choicetitle">Persoonlijke interviews</span>
                  <span class="qc-choicesub">7 diepte-interviews voor de achtergrond van klantwaardering en -voorkeuren.</span>
                </span>
              </label>
            </div>
          </div>

        </div>

        {/* ---------------- STAP 3 — Bestellen ---------------- */}
        <div class="qc-panel" data-panel="3" hidden>
          <button type="button" class="qc-back" data-goto="2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Vorige stap
          </button>
          <p class="qc-steplabel">Stap 3 van 3</p>
          <h2 class="qc-title qc-title--sm" data-step3-title>Bijna klaar</h2>

          <div class="qc-recap">
            <p class="qc-recap-title">Jouw keuzes</p>
            <ul class="qc-recap-list" data-recap></ul>
            <p class="qc-recap-price" data-recap-price>&euro; 1.500</p>
          </div>

          <form data-lead-form novalidate>
            <div class="qc-form">
              <div class="qc-fieldrow">
                <label class="qc-field">
                  <span class="qc-label">Bedrijfsnaam</span>
                  <input class="qc-input" name="bedrijf" type="text" autocomplete="organization" required />
                </label>
                <label class="qc-field">
                  <span class="qc-label">Naam</span>
                  <input class="qc-input" name="naam" type="text" autocomplete="name" required />
                </label>
              </div>
              <div class="qc-fieldrow">
                <label class="qc-field">
                  <span class="qc-label">E-mail</span>
                  <input class="qc-input" name="email" type="email" autocomplete="email" required />
                </label>
                <label class="qc-field">
                  <span class="qc-label">Telefoon <span class="qc-label-opt">(optioneel)</span></span>
                  <input class="qc-input" name="telefoon" type="tel" autocomplete="tel" />
                </label>
              </div>
              <label class="qc-field">
                <span class="qc-label">Toelichting <span class="qc-label-opt">(optioneel)</span></span>
                <textarea class="qc-textarea" name="bericht" rows="3"></textarea>
              </label>
              <label class="qc-consent">
                <input type="checkbox" name="consent" required />
                <span>Ik ga akkoord met de verwerking van mijn gegevens volgens het <a href="/privacy-statement">privacy statement</a>.</span>
              </label>
              <div hidden aria-hidden="true">
                <label>Laat dit veld leeg<input class="qc-hp" type="text" name="company_website" tabindex="-1" autocomplete="off" /></label>
              </div>
            </div>
            <p class="qc-status" role="status" aria-live="polite" data-status hidden></p>
            <button type="submit" class="btn btn-primary btn-arrow qc-cta" data-submit>Verstuur offerteaanvraag</button>
          </form>
        </div>
      </div>

      {/* Prijspaneel (desktop) */}
      <aside class="qc-summary">
        <div>
          <p class="qc-sumlabel">Jouw indicatie</p>
          <p class="qc-sumprice" data-price>&euro; 1.500</p>
          <p class="qc-sumnote">excl. btw · richtprijs op basis van je keuzes</p>
        </div>
        <div class="qc-sumdivider"></div>
        <div data-normal>
          <div class="qc-sumactions">
            <button type="button" class="btn btn-primary btn-arrow" data-action="bestellen">Direct bestellen</button>
            <button type="button" class="btn btn-outline" data-action="advies">Advies aanvragen</button>
          </div>
          <p class="qc-sumfine">Na bestelling neemt een onderzoeker binnen één werkdag contact op.</p>
        </div>
        <div data-werven hidden>
          <p class="qc-sumnote" style="margin-bottom:14px">Bij werving van respondenten verwijzen we je graag naar ons Doelgroeponderzoek.</p>
          <a href="/onze-diensten" class="btn btn-primary btn-arrow" style="width:100%">Doelgroeponderzoek</a>
        </div>
      </aside>
    </div>
  </div>

  {/* Mobiel: sticky prijsbalk */}
  <div class="qc-stickybar" data-stickybar>
    <div class="qc-stickyprice">
      <p class="qc-sumlabel">Jouw indicatie</p>
      <p class="qc-stickyamount" data-price>&euro; 1.500</p>
    </div>
    <span class="qc-stickyexcl" data-normal>excl. btw · richtprijs</span>
    <span class="qc-stickyexcl" data-werven hidden>werving → Doelgroeponderzoek</span>
    <div class="qc-stickyactions" data-normal>
      <button type="button" class="btn btn-primary btn-arrow" data-action="bestellen">Direct bestellen</button>
      <button type="button" class="btn btn-outline" data-action="advies">Advies</button>
    </div>
    <div class="qc-stickyactions" data-werven hidden>
      <a href="/onze-diensten" class="btn btn-primary btn-arrow" style="flex:1">Doelgroeponderzoek</a>
    </div>
  </div>
</section>

<script>
  import { submitCalculatorLead } from "@/scripts/submitCalculatorLead";

  // --- Rekentechniek (Calculator-config-klanttevredenheid). Alle bedragen all-in.
  const MODULE: Record<string, number> = {
    klant: 1500, // verplicht
    toekomst: 750,
    effectief: 750,
    concurrentie: 750,
  };
  const SMART_PER_MODULE = 250;
  const INTERVIEW = 1400;
  const DOORLOPEND = 3500;

  const nf = new Intl.NumberFormat("nl-NL");
  const euro = (n: number) => `€ ${nf.format(Math.round(n))}`;

  type State = {
    respondenten: "zelf" | "werven";
    frequentie: "eenmalig" | "doorlopend";
    modules: Set<string>; // bevat altijd "klant"
    smart: boolean;
    interview: boolean;
  };

  function priceFor(s: State): number {
    let total = 0;
    s.modules.forEach((m) => (total += MODULE[m] ?? 0));
    if (s.smart) total += SMART_PER_MODULE * s.modules.size;
    if (s.interview) total += INTERVIEW;
    if (s.frequentie === "doorlopend") total += DOORLOPEND;
    return total;
  }

  const MODULE_LABEL: Record<string, string> = {
    klant: "Klanttevredenheid",
    toekomst: "Toekomstwensen",
    effectief: "Effectief communiceren",
    concurrentie: "Concurrentiekracht",
  };

  // Leesbare samenvatting van de keuzes — voor de recap in stap 3 én de e-mail.
  function summaryLines(s: State): string[] {
    const lines = [
      s.frequentie === "doorlopend" ? "Doorlopend" : "Eenmalig",
      `Modules: ${[...s.modules].map((m) => MODULE_LABEL[m] ?? m).join(", ")}`,
    ];
    if (s.smart) lines.push("Smart survey");
    if (s.interview) lines.push("Persoonlijke interviews (7)");
    return lines;
  }

  document.querySelectorAll<HTMLElement>(".qcalc").forEach((root) => {
    // Alleen deze calculator afhandelen.
    if (!root.querySelector('[data-seg="respondenten"]')) return;

    const state: State = {
      respondenten: "zelf",
      frequentie: "eenmalig",
      modules: new Set(["klant"]),
      smart: false,
      interview: false,
    };
    let step = 1;
    let actie: "bestellen" | "advies" = "bestellen";
    const webhookUrl = root.dataset.webhook ?? "";

    const panels = root.querySelectorAll<HTMLElement>("[data-panel]");
    const railsteps = root.querySelectorAll<HTMLElement>("[data-railstep]");
    const prices = root.querySelectorAll<HTMLElement>("[data-price]");
    const normalBlocks = root.querySelectorAll<HTMLElement>("[data-normal]");
    const wervenBlocks = root.querySelectorAll<HTMLElement>("[data-werven]");
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-next]")!;
    const orderBtns = root.querySelectorAll<HTMLButtonElement>('[data-action="bestellen"]');
    const step3Title = root.querySelector<HTMLElement>("[data-step3-title]")!;
    const recapList = root.querySelector<HTMLElement>("[data-recap]")!;
    const recapPrice = root.querySelector<HTMLElement>("[data-recap-price]")!;
    const leadForm = root.querySelector<HTMLFormElement>("[data-lead-form]")!;
    const statusEl = root.querySelector<HTMLElement>("[data-status]")!;
    const submitBtn = root.querySelector<HTMLButtonElement>("[data-submit]")!;

    // "Direct bestellen" is alleen actief in stap 2 (stap 3 heeft z'n eigen submit-knop).
    const syncOrder = () => {
      const off = step !== 2;
      orderBtns.forEach((b) => {
        b.disabled = off;
        b.setAttribute("aria-disabled", off ? "true" : "false");
      });
    };

    const renderRecap = () => {
      step3Title.textContent = actie === "advies" ? "Adviesaanvraag versturen" : "Bijna klaar — offerte versturen";
      recapList.innerHTML = "";
      summaryLines(state).forEach((line) => {
        const li = document.createElement("li");
        li.textContent = line;
        recapList.appendChild(li);
      });
      recapPrice.textContent = euro(priceFor(state));
      submitBtn.textContent = actie === "advies" ? "Vraag advies aan" : "Verstuur offerteaanvraag";
    };

    const renderRail = () => {
      railsteps.forEach((rs) => {
        const n = Number(rs.dataset.railstep);
        const num = rs.querySelector<HTMLElement>(".qc-pillnum")!;
        const s2 = n < step ? "done" : n === step ? "active" : "todo";
        rs.dataset.state = s2;
        num.innerHTML =
          s2 === "done"
            ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>'
            : String(n);
      });
    };

    const render = () => {
      const werven = state.respondenten === "werven";
      prices.forEach((el) => (el.textContent = werven ? "- -" : euro(priceFor(state))));
      normalBlocks.forEach((el) => (el.hidden = werven));
      wervenBlocks.forEach((el) => (el.hidden = !werven));
      // Werving → geen prijs (verwijzing naar Doelgroeponderzoek): stap 2 niet bereikbaar.
      nextBtn.disabled = werven;
      nextBtn.setAttribute("aria-disabled", werven ? "true" : "false");
    };

    const goTo = (n: number) => {
      step = n;
      root.dataset.step = String(n);
      panels.forEach((p) => (p.hidden = p.dataset.panel !== String(n)));
      if (n === 3) renderRecap();
      renderRail();
      syncOrder();
      root.scrollIntoView({ behavior: "smooth", block: "start" });
    };

    // Segmented controls (respondenten / frequentie)
    root.querySelectorAll<HTMLElement>("[data-seg]").forEach((seg) => {
      const name = seg.dataset.seg!;
      seg.querySelectorAll<HTMLButtonElement>("button").forEach((btn) => {
        btn.addEventListener("click", () => {
          const v = btn.dataset.value!;
          seg.querySelectorAll<HTMLButtonElement>("button").forEach((b) => {
            const on = b === btn;
            b.classList.toggle("on", on);
            b.setAttribute("aria-pressed", on ? "true" : "false");
          });
          if (name === "respondenten") state.respondenten = v as State["respondenten"];
          else if (name === "frequentie") state.frequentie = v as State["frequentie"];
          render();
        });
      });
    });

    // Modules (multi-select)
    root.querySelectorAll<HTMLInputElement>('input[name="module"]').forEach((inp) => {
      inp.addEventListener("change", () => {
        if (inp.checked) state.modules.add(inp.value);
        else state.modules.delete(inp.value);
        render();
      });
    });

    // Add-ons (smart / interview)
    root.querySelectorAll<HTMLInputElement>('input[name="addon"]').forEach((inp) => {
      inp.addEventListener("change", () => {
        if (inp.value === "smart") state.smart = inp.checked;
        else if (inp.value === "interview") state.interview = inp.checked;
        render();
      });
    });

    nextBtn.addEventListener("click", () => goTo(2));
    root.querySelectorAll<HTMLButtonElement>("[data-goto]").forEach((b) => {
      b.addEventListener("click", () => goTo(Number(b.dataset.goto)));
    });

    // Bestellen / Advies (stap 2) → onthoud de gekozen actie en ga naar stap 3
    root.querySelectorAll<HTMLButtonElement>('[data-action="bestellen"],[data-action="advies"]').forEach((btn) => {
      btn.addEventListener("click", () => {
        actie = (btn.dataset.action as "bestellen" | "advies") ?? "bestellen";
        goTo(3);
      });
    });

    // Stap 3: echte verzending naar de n8n-webhook.
    leadForm.addEventListener("submit", async (event) => {
      event.preventDefault();

      const honeypot = leadForm.elements.namedItem("company_website") as HTMLInputElement | null;
      if (honeypot && honeypot.value.trim() !== "") {
        statusEl.hidden = false;
        statusEl.dataset.tone = "ok";
        statusEl.textContent = "Bedankt! We hebben je aanvraag ontvangen.";
        leadForm.reset();
        return;
      }

      if (!leadForm.checkValidity()) {
        leadForm.reportValidity();
        return;
      }

      const fd = new FormData(leadForm);
      const richtprijs = Math.round(priceFor(state));
      const payload = {
        calculator: "klanttevredenheid",
        actie,
        keuzes: {
          respondenten: state.respondenten,
          frequentie: state.frequentie,
          modules: [...state.modules],
          smart: state.smart,
          interview: state.interview,
        },
        richtprijs,
        richtprijsFormatted: euro(richtprijs),
        samenvatting: summaryLines(state),
        bedrijf: (fd.get("bedrijf") as string) ?? "",
        naam: (fd.get("naam") as string) ?? "",
        email: (fd.get("email") as string) ?? "",
        telefoon: (fd.get("telefoon") as string) ?? "",
        bericht: (fd.get("bericht") as string) ?? "",
        consent: fd.get("consent") === "on",
        company_website: (fd.get("company_website") as string) ?? "",
      };

      submitBtn.disabled = true;
      const originalLabel = submitBtn.textContent;
      submitBtn.textContent = "Versturen…";
      statusEl.hidden = true;

      const result = await submitCalculatorLead(webhookUrl, payload);

      statusEl.hidden = false;
      statusEl.dataset.tone = result.ok ? "ok" : "error";
      statusEl.textContent = result.message;
      submitBtn.disabled = false;
      submitBtn.textContent = originalLabel;

      if (result.ok) {
        leadForm.reset();
        root.dispatchEvent(new CustomEvent("klanttevredenheid-calculator:submit", { detail: payload, bubbles: true }));
        console.info("[klanttevredenheid-calculator] submit", payload);
      }
    });

    renderRail();
    render();
    syncOrder();
  });
</script>
