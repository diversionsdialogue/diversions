---
// Diversions site footer (omgebouwd vanuit design/components.jsx <Footer/>).
// Merk-kolom (logo + tagline + socials), kolommen Meest gelezen/Werk/Contact, basisbalk.
//
// Links verwijzen naar WERKELIJKE bestaande routes (inventaris.json). Design-items
// zonder bestemming zijn WEGGELATEN en GEFLAGD in het rapport:
//   - "Team", "Vacatures", "Pers", "Proces" -> geen bestaande pagina -> weggelaten.
//   - Social-URL's (#) + telefoon/adres -> design-placeholders, eigenaar vult aan.
const year = new Date().getFullYear();

// "Meest gelezen": de vier onderzoeken uit de services-sectie op de home
// (apps/web/src/pages/index.astro). Labels + routes 1-op-1 met de home gehouden.
const mostReadLinks = [
  { name: "Klanttevredenheid", href: "/services/klanttevredenheidsonderzoek" },
  { name: "Customer journey", href: "/services/customer-journey" },
  { name: "Campagne-effect", href: "/services/campagne-effectonderzoek" },
  { name: "Pretest", href: "/services/pretest" },
];
const workLinks = [
  { name: "Cases", href: "/work" },
  { name: "Services", href: "/onze-diensten" },
  { name: "Blog", href: "/blog" },
];
const legalLinks = [
  { name: "Privacy", href: "/privacy-statement" },
  { name: "Voorwaarden", href: "/diversions-algemene-voorwaarden" },
  { name: "Cookies", href: "/cookie-statement" },
];
---

<footer class="site-footer">
  <div class="footer-grid">
    <div class="footer-col footer-brand">
      {/* Transparante variant: de standaard-SVG heeft een wit achtergrondvlak dat
          op de cremekleurige footer als witte rechthoek zichtbaar is. */}
      <img src="/diversions-logo-transparant.svg" alt="Diversions" width="96" height="30" />
      <p class="footer-tagline">
        Insights &amp; oplossingen. We helpen organisaties klaar te staan voor de
        klant van vandaag en morgen. Van onderzoek tot resultaat.
      </p>
      <div class="footer-socials">
        <a href="https://nl.linkedin.com/company/diversions" class="icon-btn" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"
            ><rect x="3" y="3" width="18" height="18" rx="3"></rect><path d="M8 10v7M8 7v.01M12 17v-4a2 2 0 0 1 4 0v4M12 13v4"></path></svg
          >
        </a>
        <a href="https://www.generationjourney.nl/" class="icon-btn" aria-label="Generation Journey website" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"
            ><circle cx="12" cy="12" r="9"></circle><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"></path></svg
          >
        </a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Meest gelezen</h4>
      {mostReadLinks.map((l) => <a href={l.href}>{l.name}</a>)}
    </div>

    <div class="footer-col">
      <h4>Werk</h4>
      {workLinks.map((l) => <a href={l.href}>{l.name}</a>)}
    </div>

    <div class="footer-col">
      <h4>Contact</h4>
      <a href="tel:+31552032193">055 20 32 193</a>
      <a
        href="https://www.google.com/maps/search/?api=1&query=Prins+Willem-Alexanderlaan+705+7311+ST+Apeldoorn"
        target="_blank"
        rel="noopener noreferrer"
      >
        Prins Willem-Alexanderlaan 705,<br />7311 ST Apeldoorn
      </a>
      <a href="mailto:info@diversions.nl">info@diversions.nl</a>
    </div>
  </div>

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      name: "Diversions",
      url: "https://diversions.nl",
      email: "info@diversions.nl",
      telephone: "+31552032193",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Prins Willem-Alexanderlaan 705",
        postalCode: "7311 ST",
        addressLocality: "Apeldoorn",
        addressCountry: "NL",
      },
    })}
  />

  <div class="footer-base">
    <span>© {year} Diversions. Van inzichten naar oplossingen.</span>
    <div class="footer-legal">
      {legalLinks.map((l) => <a href={l.href}>{l.name}</a>)}
    </div>
  </div>
</footer>
