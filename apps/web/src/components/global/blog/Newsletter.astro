---
/**
 * Newsletter — statische nieuwsbrief-strip in de design-stijl.
 * Omgebouwd vanuit design/blog-components.jsx <Newsletter/>.
 *
 * LET OP: dit formulier is BEWUST NIET BEDRAAD. De submit-afhandeling
 * (n8n-webhook + AVG-consent) hoort bij Fase 4 (forms-agent), net als de
 * overige formulieren op de site. Voorlopig is het puur presentatie.
 */
---

<div class="newsletter">
  <h3>Nieuwsbrief — éénmaal per maand</h3>
  <p>Korte updates over wat we maken, lezen en denken. Geen marketing-spam.</p>
  {/* FASE 4 (forms-agent): action/handler + consent toevoegen via n8n. */}
  <form
    onsubmit="return false;"
    aria-label="Nieuwsbrief aanmelden (nog niet actief)"
  >
    <label class="sr-only" for="newsletter-email">E-mailadres</label>
    <input
      type="email"
      id="newsletter-email"
      name="email"
      placeholder="jij@bedrijf.nl"
      autocomplete="email"
    />
    <button type="submit" class="btn btn-primary">Aanmelden</button>
  </form>
</div>
