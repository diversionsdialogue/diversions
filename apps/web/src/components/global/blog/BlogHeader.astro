---
/**
 * BlogHeader — minimale header voor blogartikelen.
 * Omgebouwd vanuit design/blog-components.jsx <BlogHeader/>.
 * Toont: "← Terug naar Diversions" (naar /), logo (naar /), contact-icoon (naar /contact).
 * Gebruikt de bestaande .site-header / .back-link / .brand / .icon-btn-stijlen
 * (de hoofdnav-/CTA-elementen ontbreken hier bewust; geen .blog-template-scope nodig
 * omdat dit een eigen header-markup is zonder die elementen).
 */
---

<header class="site-header blog-header">
  <a href="/" class="back-link" aria-label="Terug naar Diversions">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
      <path
        d="M9 11.5 4.5 7 9 2.5"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
    Terug naar Diversions
  </a>

  <a href="/" class="brand" aria-label="Diversions home">
    <img src="/diversions-logo.svg" alt="Diversions" width="130" height="30" />
  </a>

  <div class="header-actions">
    <a href="/contact" class="icon-btn" aria-label="Contact">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <rect x="3" y="5" width="18" height="14" rx="2"></rect>
        <path d="m3 7 9 6 9-6"></path>
      </svg>
    </a>
  </div>
</header>
