---
/**
 * Picture — <picture> met AVIF → WebP → originele fallback voor afbeeldingen
 * in /public (die Astro niet zelf optimaliseert).
 *
 * `src` is het fallback-bestand (bv. /img/foo.jpg of /img/logo.png); de avif/
 * webp-varianten worden afgeleid door de extensie te vervangen. Die varianten
 * moeten bestaan (zie scripts/optimize-public-images.mjs).
 */
interface Props {
  src: string;
  alt?: string;
  class?: string;
  loading?: "lazy" | "eager";
  width?: number;
  height?: number;
  sizes?: string;
}
const { src, alt = "", class: className, loading = "lazy", width, height, sizes } = Astro.props;
const base = src.replace(/\.(png|jpe?g|webp|avif)$/i, "");
---
<picture>
  <source srcset={`${base}.avif`} type="image/avif" />
  <source srcset={`${base}.webp`} type="image/webp" />
  <img
    src={src}
    alt={alt}
    class={className}
    loading={loading}
    decoding="async"
    width={width}
    height={height}
    sizes={sizes}
  />
</picture>
