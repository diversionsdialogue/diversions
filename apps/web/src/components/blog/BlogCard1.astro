---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
// Content
const rawImage = Astro.props.post.data.image?.url;
const { title, description, url, author, pubDate, imageSrc, imageAlt } = {
  url: "/blog/" + (Astro.props.post.slug ?? Astro.props.post.id),
  title: Astro.props.post.data.title,
  author: Astro.props.post.data.author,
  description: Astro.props.post.data.description,
  // Ondersteunt zowel een Sanity-CDN-URL (string) als een Astro-image (ImageMetadata).
  imageSrc: typeof rawImage === "string" ? rawImage : (rawImage?.src ?? ""),
  imageAlt: Astro.props.post.data.image?.alt ?? "",
  pubDate: new Date(Astro.props.post.data.pubDate).toLocaleDateString("nl-NL", {
    year: "numeric",
    month: "long",
    day: "2-digit",
  }),
};
---

<div class="relative flex flex-col items-start h-full justify-between group">
  <a href={url} title={title} class="absolute inset-0 z-10"></a>
  <div>
    {
      imageSrc ? (
        <img
          src={imageSrc}
          width="800"
          height="500"
          alt={imageAlt}
          loading="lazy"
          decoding="async"
          class="aspect-16/10 w-full rounded-2xl object-cover object-center mb-6"
        />
      ) : null
    }
    <span class="text-xs text-accent-400 font-medium"
      >{author} on {pubDate}
    </span>
    <Text
      tag="h3"
      variant="textLG"
      class="text-accent-500 mt-6 group-hover:text-pink-500"
    >
      {title}
    </Text>
    <Text
      tag="p"
      variant="textBase"
      class="text-accent-500 mt-2 text-pretty items-center"
    >
      {description}
    </Text>
  </div>
</div>
